# Build artifacts
/bin/
/dist/
*.out
coverage.out

# Stray dev binaries — `go build` from inside a module dir writes here
# (named after the dir). Build into /bin/ with `go build -o ../bin/…`.
/runner/runner
/mcp/mcp
/mcp/bin/
/emisar
/emisar-mcp

# Local runtime state from the example config
/runner/examples/var/

# Cross-compile output (the release workflows' go build matrix)
emisar-*-linux-*
emisar-*-darwin-*

# Test JSONL logs that might be dropped if a test forgets to t.TempDir()
events.jsonl
events.jsonl.cursor
events.jsonl.*

# Erlang/BEAM crash dumps — written to the CWD when the VM aborts.
erl_crash.dump

# Editor noise
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.claude/scheduled_tasks.lock

# Local dev compose secrets — copy .env.example to .env and fill in.
/.env

docs/

# .agent/ is local working state — only rules/ (the shared taste KB) is committed.
# Tasks, backlog, ideas, pending-decisions, log, archive all stay on the machine
# (no commit noise, no cross-agent merge conflicts). See AGENTS.md.
**/.agent/*
!**/.agent/rules
.expert/*.log
.claude/.batch-active
