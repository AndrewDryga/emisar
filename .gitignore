# Build artifacts
/bin/
/dist/
*.out
coverage.out
/test-results/

# Stray dev binaries — `go build` from inside a module dir writes here
# (named after the dir). Build into /bin/ with `go build -o ../bin/…`.
/runner/runner
/mcp/mcp
/mcp/bin/
/emisar
/emisar-mcp

# Local runtime state from the example config
/runner/examples/var/

# Cross-compile output (the release workflows' go build matrix)
emisar-*-linux-*
emisar-*-darwin-*

# Test JSONL logs that might be dropped if a test forgets to t.TempDir()
events.jsonl
events.jsonl.cursor
events.jsonl.*

# Erlang/BEAM crash dumps — written to the CWD when the VM aborts.
erl_crash.dump

# Editor noise
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.claude/scheduled_tasks.lock

# Local dev compose secrets — copy .env.example to .env and fill in.
/.env

# Repository documentation is always tracked. Working notes and agent history
# belong under the ignored .agent/ state below, never as hidden files in docs/.

# .agent/ is local working state — only the KNOWLEDGE and CONFIG are committed:
# rules/ (the shared taste KB), kb/ (the descriptive knowledge base), presets/
# (orchestration recipes), scripts/ (maintained dev tooling), project.yaml
# (monorepo members + serve ports), and loop.yaml (the unattended-loop config).
# Tasks, the backlog drawer, pending decisions, log, archive all stay on the
# machine (no commit noise, no cross-agent merge conflicts). See AGENTS.md.
**/.agent/*
!**/.agent/rules
!**/.agent/scripts
!**/.agent/kb
!**/.agent/presets
!.agent/project.yaml
!.agent/loop.yaml
!.agent/compose.yml
.expert/*.log
.claude/.sweep-active

# Self-signed dev/e2e TLS certs (mix phx.gen.cert)
**/priv/cert/

# Terraform (infra/) — state and real var files never get committed; the provider
# lock (.terraform.lock.hcl) and *.tfvars.example DO. State can hold sensitive
# values and drifts per-operator; tfvars may carry real values.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
