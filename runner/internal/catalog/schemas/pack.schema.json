{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emisar.dev/v1/schemas/pack.schema.json",
  "title": "emisar pack manifest (pack.yaml)",
  "description": "Authoring schema for a pack's pack.yaml. Documentation and editor validation only — the runner's loader (runner/pkg/packspec) is the authoritative validator and the content hash is the trust source.",
  "type": "object",
  "required": ["schema_version", "id", "name", "version", "description", "actions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$",
      "maxLength": 128,
      "description": "Dot-namespaced lowercase id, each segment [a-z][a-z0-9_-]*."
    },
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1, "description": "Bumped on any contract change; new packs start at 0.1.0."},
    "description": {"type": "string", "minLength": 1},
    "vendor": {"type": "string"},
    "homepage": {"type": "string", "format": "uri"},
    "allow_symlinks": {"type": "boolean"},
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": {"type": "array", "items": {"type": "string"}},
        "binaries": {"type": "array", "items": {"type": "string"}}
      }
    },
    "detect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binaries": {"type": "array", "items": {"type": "string"}},
        "processes": {"type": "array", "items": {"type": "string"}},
        "ports": {"type": "array", "items": {"type": "integer", "minimum": 1, "maximum": 65535}}
      }
    },
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string"},
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
              "required": {"type": "boolean"},
              "description": {"type": "string"},
              "default": {"type": "string"},
              "example": {"type": "string"}
            }
          }
        },
        "notes": {"type": "array", "items": {"type": "string"}},
        "verify": {"type": "string", "description": "Id of a low-risk read action in this pack."}
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "description": "Path to an action YAML relative to the pack root, e.g. actions/disk_usage.yaml."}
    }
  }
}
