{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emisar.dev/v1/schemas/catalog.schema.json",
  "title": "emisar pack registry catalog",
  "description": "The published catalog.json contract: the full set of installable packs with their content hashes, immutable tarball URLs, detect signals, and action summaries. Emitted by `emisar pack catalog build`. Trust rests on content_hash + the runner's re-hash, not on this document.",
  "type": "object",
  "required": ["schema_version", "packs"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "packs": {"type": "array", "items": {"$ref": "#/$defs/pack"}}
  },
  "$defs": {
    "pack": {
      "type": "object",
      "required": [
        "id", "name", "version", "description", "vendor", "homepage",
        "source_url", "content_hash", "tarball_url", "requires", "detect", "actions"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "vendor": {"type": "string"},
        "homepage": {"type": "string", "format": "uri"},
        "source_url": {"type": "string", "format": "uri"},
        "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "tarball_url": {"type": "string", "format": "uri"},
        "requires": {
          "type": "object",
          "required": ["os", "binaries"],
          "additionalProperties": false,
          "properties": {
            "os": {"type": "array", "items": {"type": "string"}},
            "binaries": {"type": "array", "items": {"type": "string"}}
          }
        },
        "detect": {"$ref": "#/$defs/detect"},
        "actions": {"type": "array", "items": {"$ref": "#/$defs/action"}},
        "previous_versions": {"type": "array", "items": {"$ref": "#/$defs/previous_version"}},
        "retired_below": {"type": "string", "minLength": 1}
      }
    },
    "previous_version": {
      "type": "object",
      "required": ["version", "content_hash", "tarball_url"],
      "additionalProperties": false,
      "properties": {
        "version": {"type": "string", "minLength": 1},
        "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "tarball_url": {"type": "string", "format": "uri"}
      }
    },
    "detect": {
      "type": "object",
      "required": ["binaries", "processes", "ports"],
      "additionalProperties": false,
      "properties": {
        "binaries": {"type": "array", "items": {"type": "string"}},
        "processes": {"type": "array", "items": {"type": "string"}},
        "ports": {"type": "array", "items": {"type": "integer", "minimum": 1, "maximum": 65535}}
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "title", "kind", "risk"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "kind": {"type": "string", "enum": ["exec", "script"]},
        "risk": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "command": {
          "type": "object",
          "required": ["binary", "argv"],
          "additionalProperties": false,
          "properties": {
            "binary": {"type": "string"},
            "argv": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    }
  }
}
