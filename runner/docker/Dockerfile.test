# Dockerfile.test builds a minimal Debian-based image with the Go
# toolchain pinned to the repo's go.mod version. It exists so dev
# machines (including macOS) can run the test suite in a real Linux
# environment — important for verifying Pdeathsig, Setpgid, and the
# /var/log → /private/var/log symlink behaviour that differs across
# platforms.
#
# Usage (run from repo root):
#   docker build -f runner/docker/Dockerfile.test -t emisar-test .
#   docker run --rm emisar-test

# Base image is digest-pinned for supply-chain integrity: the tag documents
# the version, the @sha256 pins the exact multi-arch index so a rebuild is
# reproducible and a moved tag can't swap the base out. Refresh with:
#   docker buildx imagetools inspect golang:1.26-bookworm --format '{{.Manifest.Digest}}'
FROM golang:1.26-bookworm@sha256:18aedc16aa19b3fd7ded7245fc14b109e054d65d22ed53c355c899582bbb2113

# bash is needed by the executor tests that use /bin/sh -c with trap.
# (debian:bookworm-slim already has /bin/sh as dash; we want a real
# bash for `trap 'exit 42' TERM` to work as our tests expect.)
RUN apt-get update \
 && apt-get install -y --no-install-recommends bash ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/runner

# Pre-fetch modules so each `docker run` doesn't re-download them.
# Cache layers: copy go.mod/go.sum first, then sources.
COPY runner/go.mod runner/go.sum ./
RUN go mod download

# Copy the runner module plus the real pack definitions its cross-project
# security contract tests load. The repo-root .dockerignore keeps build state,
# dependencies, and operator-local files out of the context.
COPY runner/ .
COPY packs/ /workspace/packs/

# Default command: race-enabled tests across the runner module.
# Override with `docker run ... go test ./internal/executor/...` for
# package-scoped runs.
CMD ["go", "test", "-race", "-count=1", "./..."]
