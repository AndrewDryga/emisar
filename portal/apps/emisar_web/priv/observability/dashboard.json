{
  "title": "emisar control plane",
  "uid": "emisar-control-plane",
  "tags": ["emisar"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Runs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Run outcome rate (by status)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Finished runs/sec by terminal status. emisar_run_finished_count is fleet-wide (never tagged by account).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (status) (rate(emisar_run_finished_count[5m]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 3,
      "title": "Run failure rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Share of finished runs that failed ON THE HOST (failed/error/timed_out/refused) — excludes policy denials and bad-input rejections.",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.2 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(emisar_run_finished_count{status=~\"failed|error|timed_out|refused\"}[5m])) / clamp_min(sum(rate(emisar_run_finished_count[5m])), 1)", "legendFormat": "failure rate" }
      ]
    },
    {
      "id": 4,
      "title": "Run duration p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "95th-percentile wall-clock duration of finished runs.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(emisar_run_finished_duration_ms_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Approvals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "title": "Approvals pending",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Unresolved approval requests across the fleet (gauge).",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 20 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_approvals_pending_count", "legendFormat": "pending" }
      ]
    },
    {
      "id": 12,
      "title": "Oldest pending approval",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Age of the longest-waiting unresolved approval. The core SLO: gated actions should be decided promptly (alert fires at 30m).",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 900 }, { "color": "red", "value": 1800 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_approvals_pending_oldest_age_seconds", "legendFormat": "oldest age" }
      ]
    },
    {
      "id": 13,
      "title": "Approval decisions (by decision)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Resolved approvals/sec by terminal decision (approved / denied / expired).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (decision) (rate(emisar_approval_decided_count[5m]))", "legendFormat": "{{decision}}" }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Fleet & background",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 21,
      "title": "Runner connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Runner connection tally from the durable connection record (gauge). Presence is the live per-account truth; this trails an ungraceful drop.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_runners_connection_connected", "legendFormat": "connected" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_runners_connection_disconnected", "legendFormat": "disconnected" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_runners_connection_never_connected", "legendFormat": "never connected" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_runners_connection_disabled", "legendFormat": "disabled" }
      ]
    },
    {
      "id": 22,
      "title": "Oban queue backlog (by queue)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Available (waiting) Oban jobs per queue (gauge) — the 'jobs piling up' signal.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "emisar_oban_queue_available", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "id": 23,
      "title": "Billing webhooks (by outcome)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Paddle webhook events processed, by outcome (applied / duplicate / failed).",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (outcome) (increase(emisar_billing_webhook_count[1h]))", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 24,
      "title": "DB query time p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "95th-percentile query execution time.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(emisar_repo_query_query_time_bucket[5m])))", "legendFormat": "query p95" }
      ]
    },
    {
      "id": 25,
      "title": "BEAM atom count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "The atom table never GCs — a steady climb is the IL-14 early-warning line (unbounded String.to_atom on untrusted input).",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 500000 }, { "color": "red", "value": 1000000 } ] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "vm_system_counts_atom_count", "legendFormat": "atoms" }
      ]
    }
  ]
}
