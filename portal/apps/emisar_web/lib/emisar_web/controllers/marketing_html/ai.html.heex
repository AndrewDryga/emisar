<%!-- ============================================================
  /ai — emisar landing, benefit-first
  Give your AI assistant safe, gated access to your infrastructure.
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100 antialiased selection:bg-indigo-500/30">
  <.marketing_nav current_user={@current_user} current={:ai} sticky />

  <%!-- Hero --%>
  <section class="relative flex min-h-[600px] items-center overflow-hidden border-b border-zinc-900 bg-zinc-950">
    <div class="hero-grid absolute inset-0" aria-hidden="true"></div>
    <div class="hero-glow absolute inset-0" aria-hidden="true"></div>

    <div class="relative mx-auto w-full max-w-7xl px-6 py-24 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-8 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-zinc-950/80 px-4 py-1 text-xs font-semibold text-indigo-300">
          <.icon name="hero-sparkles" class="h-3.5 w-3.5" /> AI&nbsp;+&nbsp;your infrastructure
        </p>
        <.marketing_heading tag="h1" scale={:display}>
          Give your AI a safe key to your infrastructure.
        </.marketing_heading>
        <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-zinc-300">
          Install a runner, connect your LLM over MCP, and Claude, ChatGPT, or Cursor can read
          your logs, query your metrics, and investigate an incident right alongside you — across
          your whole fleet. Every action is pre-declared, policy-gated, approved by a human when
          it's risky, and written to an audit trail. No SSH. No standing access.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <.marketing_button href={~p"/sign_up"} icon="hero-arrow-right">
            Start free
          </.marketing_button>
          <.marketing_button variant={:secondary} href="#watch">
            Watch it work
          </.marketing_button>
        </div>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-zinc-400">
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-shield-check" class="h-4 w-4 text-indigo-400" />
            No SSH, no standing access
          </span>
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-hand-raised" class="h-4 w-4 text-indigo-400" />
            Human approval on risky actions
          </span>
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-eye-slash" class="h-4 w-4 text-indigo-400" />
            Secrets redacted on the host
          </span>
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-document-check" class="h-4 w-4 text-indigo-400" />
            Every action audited
          </span>
        </div>
      </div>
    </div>
  </section>

  <%!-- The gap: why this is needed at all --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center lg:px-8">
      <h2 class="text-base font-semibold text-indigo-400">The gap</h2>
      <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Your AI is brilliant — and blind.
      </p>
      <p class="mt-6 text-lg leading-relaxed text-zinc-400">
        It can reason about your code all day, but it can't see your running systems. So when
        something breaks, <span class="text-zinc-200">you</span>
        become its eyes — pasting <code class="rounded bg-zinc-900 px-1 py-0.5 text-sm text-indigo-300">journalctl</code>, <code class="rounded bg-zinc-900 px-1 py-0.5 text-sm text-indigo-300">kubectl</code>, and
        Grafana screenshots into a chat box at 2&nbsp;a.m. emisar closes that gap: it gives your
        assistant its own safe, gated hands on the infrastructure — so it can look, and help.
      </p>
    </div>
  </section>

  <%!-- How it works — the three-step mental model --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">How it works</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Three steps to an AI that can actually help.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:max-w-none lg:grid-cols-3">
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8">
          <span class="absolute right-6 top-6 font-mono text-sm font-semibold text-zinc-700">
            01
          </span>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-server-stack" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Install the runner</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            One command on each host. The runner dials
            <em class="text-zinc-300 not-italic">out</em>
            over a websocket — no inbound ports, no bastion — and loads only the action packs you
            choose for that machine.
          </p>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8">
          <span class="absolute right-6 top-6 font-mono text-sm font-semibold text-zinc-700">
            02
          </span>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-puzzle-piece" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Connect your LLM</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Point any MCP client at emisar. Claude.ai and ChatGPT connect over OAuth; Claude Code,
            Claude Desktop, Cursor, Gemini CLI, and Codex use the
            <code class="rounded bg-zinc-900 px-1 py-0.5 text-xs text-indigo-300">
              emisar-mcp
            </code>
            stdio bridge.
          </p>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8">
          <span class="absolute right-6 top-6 font-mono text-sm font-semibold text-zinc-700">
            03
          </span>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-sparkles" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Ask in plain English</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            "Why is checkout slow?" Your assistant investigates through a finite catalog of declared
            actions — and stops for your approval before it does anything risky.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%!-- What your AI can do — the magic, made concrete --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">What your AI can do</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Read everything. Touch only what you allow.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400">
          The same catalog a human operator would reach for — exposed to your AI as typed,
          validated tools.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-indigo-300">
            <.icon name="hero-document-text" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Read &amp; tail logs</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            journald, nginx and Apache access/error logs, application logs — searched and tailed live.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-indigo-300">
            <.icon name="hero-signal" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Query metrics</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Prometheus, VictoriaMetrics, and Grafana — ask in plain language, get the series back.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-indigo-300">
            <.icon name="hero-cpu-chip" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Inspect the host</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Processes, memory, disk, systemd units, and Docker containers — the whole vital-signs panel.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-indigo-300">
            <.icon name="hero-circle-stack" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Check your datastores</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Postgres, MongoDB, Redis, Cassandra, ClickHouse, and CockroachDB — health, locks, replication.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-indigo-300">
            <.icon name="hero-globe-alt" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Trace the network</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            DNS, TLS certificates, connectivity, routes, and firewall state — from the host's own view.
          </p>
        </div>
        <div class="rounded-2xl border border-indigo-500/30 bg-indigo-500/[0.04] p-7 transition hover:-translate-y-0.5 hover:border-indigo-500/50">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-300">
            <.icon name="hero-wrench-screwdriver" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Act — behind approval</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Restart a unit, stop a runaway job, fail over, scale a service — each one gated on a
            human click.
          </p>
        </div>
      </div>

      <p class="mx-auto mt-12 max-w-2xl text-center text-sm text-zinc-500">
        Dozens of packs spanning Linux, databases, Kubernetes, and your cloud — install what you
        run, or author your own.
        <.link navigate={~p"/packs"} class="font-medium text-indigo-300 hover:text-indigo-200">
          Browse the catalog →
        </.link>
      </p>
    </div>
  </section>

  <%!-- Watch it work — the live incident transcript --%>
  <section id="watch" class="scroll-mt-20 border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Watch it work</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          A real incident, start to finish.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400">
          One host, one connected LLM. A CSI driver reformatted a live disk and wiped 33 hours of
          metrics. Watch the agent investigate through declared actions, stop the writes behind one
          approval, and hand back the durable fix — over MCP, no SSH, every step on the record.
        </p>
      </div>

      <.emisar_demo />
    </div>
  </section>

  <%!-- Safe by construction — the security spine, the reason you can allow this --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Safe by construction</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The reason you can actually allow this.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400">
          "Give an AI access to prod" sounds reckless — until access means a finite, gated, audited
          catalog instead of a shell. Six guarantees do the work.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-800 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
        <div class="bg-zinc-950 p-8">
          <.icon name="hero-cube" class="h-6 w-6 text-indigo-400" />
          <h3 class="mt-5 text-base font-semibold text-white">A finite, declared catalog</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            The model can only call actions declared in a content-hashed pack. Undeclared commands
            don't exist to it — there's nothing to jailbreak into.
          </p>
        </div>
        <div class="bg-zinc-950 p-8">
          <.icon name="hero-lock-closed" class="h-6 w-6 text-indigo-400" />
          <h3 class="mt-5 text-base font-semibold text-white">No SSH, no standing access</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            The runner dials out and holds no inbound port. There's no shell to hand over and no
            long-lived key for an AI — or an attacker — to leak.
          </p>
        </div>
        <div class="bg-zinc-950 p-8">
          <.icon name="hero-scale" class="h-6 w-6 text-indigo-400" />
          <h3 class="mt-5 text-base font-semibold text-white">Policy on every call</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Reads run free; risky writes stop for a human approval that shows the actor, the
            arguments, and the target host. The destructive verbs are deny-by-default.
          </p>
        </div>
        <div class="bg-zinc-950 p-8">
          <.icon name="hero-finger-print" class="h-6 w-6 text-indigo-400" />
          <h3 class="mt-5 text-base font-semibold text-white">Re-validated on the host</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Every argument is checked against the action's schema on the runner before anything
            executes — the cloud's word is never taken on faith.
          </p>
        </div>
        <div class="bg-zinc-950 p-8">
          <.icon name="hero-eye-slash" class="h-6 w-6 text-indigo-400" />
          <h3 class="mt-5 text-base font-semibold text-white">Secrets never leave</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Output is redacted on the host — AWS keys, JWTs, bearer tokens, and your own patterns —
            before a byte is forwarded. The control plane never sees a raw secret.
          </p>
        </div>
        <div class="bg-zinc-950 p-8">
          <.icon name="hero-document-magnifying-glass" class="h-6 w-6 text-indigo-400" />
          <h3 class="mt-5 text-base font-semibold text-white">Everything on the record</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Who, what, when, and <span class="text-zinc-300">why</span> — a searchable audit trail
            backed by a hash-chained runner journal. Stream it to your SIEM.
          </p>
        </div>
      </div>

      <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-zinc-500">
        Enforcing runners can even refuse any dispatch that isn't signed by a key you trust.
        <.link navigate={~p"/security"} class="font-medium text-indigo-300 hover:text-indigo-200">
          See the full security model →
        </.link>
      </p>
    </div>
  </section>

  <%!-- Built for teams / enterprise --%>
  <section class="border-t border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">For teams</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Built for teams, ready for enterprise.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
        <div class="flex gap-4">
          <.icon name="hero-identification" class="h-6 w-6 flex-none text-indigo-400" />
          <div>
            <h3 class="text-base font-semibold text-white">SSO &amp; directory sync</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              OIDC sign-in with Okta, Google Workspace, or Keycloak, plus SCIM — offboarding in your
              IdP revokes emisar access automatically.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <.icon name="hero-user-group" class="h-6 w-6 flex-none text-indigo-400" />
          <div>
            <h3 class="text-base font-semibold text-white">Roles &amp; runner scopes</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              Owner, admin, operator, and viewer — plus per-member scopes so an operator only sees
              the hosts they own.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <.icon name="hero-finger-print" class="h-6 w-6 flex-none text-indigo-400" />
          <div>
            <h3 class="text-base font-semibold text-white">Account-wide MFA</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              Enforce two-factor across the whole team, with recovery codes and admin reset for the
              locked-out.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <.icon name="hero-arrow-up-tray" class="h-6 w-6 flex-none text-indigo-400" />
          <div>
            <h3 class="text-base font-semibold text-white">Audit → SIEM</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              Stream every event as NDJSON to your SIEM with a read-only key and cursor pagination —
              the record lives in your stack too.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <.icon name="hero-key" class="h-6 w-6 flex-none text-indigo-400" />
          <div>
            <h3 class="text-base font-semibold text-white">Scoped, revocable keys</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              Issue a narrow API key per agent — scoped to the actions and runners it needs — and
              revoke it the instant you need to.
            </p>
          </div>
        </div>
        <div class="flex gap-4">
          <.icon name="hero-queue-list" class="h-6 w-6 flex-none text-indigo-400" />
          <div>
            <h3 class="text-base font-semibold text-white">Runbooks</h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">
              Save gated, multi-step operational sequences your team approves once — and let the AI
              read them as playbooks over MCP.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-14 flex flex-wrap justify-center gap-4">
        <.marketing_button variant={:secondary} navigate={~p"/docs/sso"} icon="hero-arrow-right">
          SSO &amp; directory sync
        </.marketing_button>
        <.marketing_button variant={:secondary} navigate={~p"/docs/teams-and-access"}>
          Teams &amp; access
        </.marketing_button>
      </div>
    </div>
  </section>

  <%!-- FAQ — visible accordion + the FAQPage JSON-LD share @ai_faqs --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-indigo-400">FAQ</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The questions you're already asking.
        </p>
      </div>

      <div class="mt-16 divide-y divide-zinc-900 rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between px-8 py-6 text-base font-semibold text-white">
              {q}
              <.icon name="hero-plus" class="h-5 w-5 text-zinc-500 transition group-open:hidden" />
              <.icon name="hero-minus" class="hidden h-5 w-5 text-indigo-400 group-open:block" />
            </summary>
            <p class="px-8 pb-6 text-sm leading-relaxed text-zinc-400">{a}</p>
          </details>
        <% end %>
      </div>
    </div>
  </section>

  <.marketing_cta
    headline="Give your AI a safe key to production."
    subcopy="Install a runner, connect your LLM, and run your first policy-gated action in minutes. Free for three runners — no credit card."
    secondary_label="Read the quickstart"
    secondary_path={~p"/docs/quickstart"}
  />

  <.marketing_footer />
</div>
