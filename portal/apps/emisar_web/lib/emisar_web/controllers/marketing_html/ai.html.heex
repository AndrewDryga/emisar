<%!-- ============================================================
  /ai — emisar landing, benefit-first
  Give your AI assistant safe, gated access to your infrastructure.
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100 antialiased">
  <.marketing_nav current_user={@current_user} current={:ai} sticky />

  <%!-- Hero --%>
  <section class="relative flex min-h-[600px] items-center overflow-hidden border-b border-zinc-900 bg-zinc-950">
    <div class="hero-grid absolute inset-0" aria-hidden="true"></div>

    <div class="relative mx-auto w-full max-w-7xl px-6 py-24 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-8 inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-zinc-950/80 px-4 py-1 text-xs font-semibold text-brand-300">
          <.icon name="hero-sparkles" class="h-3.5 w-3.5" /> For your AI assistant
        </p>
        <.marketing_heading tag="h1" scale={:display}>
          Your AI is brilliant. And blind.
        </.marketing_heading>
        <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-zinc-300">
          Claude, Cursor, and ChatGPT reason about your code all day — but they can't see your
          running systems. emisar gives your assistant safe, gated eyes on production: read logs,
          query metrics, and investigate an incident, right alongside you. You stay in control of
          anything that changes — no SSH, no pasting Grafana screenshots into a chat box at 2&nbsp;a.m.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <.marketing_button href={~p"/sign_up"} icon="hero-arrow-right">
            Start free
          </.marketing_button>
          <.marketing_button variant={:secondary} navigate={~p"/use-cases/csi-data-loss"}>
            See it run an incident
          </.marketing_button>
        </div>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-zinc-400">
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-shield-check" class="h-4 w-4 text-brand-400" />
            No SSH, no standing access
          </span>
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-hand-raised" class="h-4 w-4 text-brand-400" />
            Human approval on risky actions
          </span>
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-eye-slash" class="h-4 w-4 text-brand-400" />
            Secrets redacted on the host
          </span>
          <span class="inline-flex items-center gap-1.5">
            <.icon name="hero-document-check" class="h-4 w-4 text-brand-400" />
            Every action audited
          </span>
        </div>
      </div>
    </div>
  </section>

  <%!-- How it works — the three-step mental model --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">How it works</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Three steps to an AI that can actually help.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:max-w-none lg:grid-cols-3">
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8">
          <span class="absolute right-6 top-6 font-mono text-sm font-semibold text-zinc-700">
            01
          </span>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name="hero-server-stack" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Install the runner</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            One command on each host. The runner dials
            <em class="text-zinc-300 not-italic">out</em>
            over a websocket — no inbound ports, no bastion — and loads only the action packs you
            choose for that machine.
          </p>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8">
          <span class="absolute right-6 top-6 font-mono text-sm font-semibold text-zinc-700">
            02
          </span>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name="hero-puzzle-piece" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Connect your LLM</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Point any MCP client at emisar. Claude.ai and ChatGPT connect over OAuth; Claude Code,
            Claude Desktop, Cursor, Gemini CLI, and Codex use the
            <code class="rounded bg-zinc-900 px-1 py-0.5 text-xs text-brand-300">
              emisar-mcp
            </code>
            stdio bridge.
          </p>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8">
          <span class="absolute right-6 top-6 font-mono text-sm font-semibold text-zinc-700">
            03
          </span>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name="hero-sparkles" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Ask in plain English</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            "Why is checkout slow?" Your assistant investigates through a finite catalog of declared
            actions — and stops for your approval before it does anything risky.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%!-- What your AI can do — the magic, made concrete --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">What your AI can do</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Read everything. Touch only what you allow.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400 text-pretty">
          The same catalog a human operator would reach for — exposed to your AI as typed,
          validated tools.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:max-w-none lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-brand-300">
            <.icon name="hero-document-text" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Read &amp; tail logs</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            journald, nginx and Apache access/error logs, application logs — searched and tailed live.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-brand-300">
            <.icon name="hero-signal" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Query metrics</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Prometheus, VictoriaMetrics, and Grafana — ask in plain language, get the series back.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-brand-300">
            <.icon name="hero-cpu-chip" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Inspect the host</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Processes, memory, disk, systemd units, and Docker containers — the whole vital-signs panel.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-brand-300">
            <.icon name="hero-circle-stack" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Check your datastores</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Postgres, MongoDB, Redis, Cassandra, ClickHouse, and CockroachDB — health, locks, replication.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-7 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800/80 text-brand-300">
            <.icon name="hero-globe-alt" class="h-5 w-5" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Trace the network</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            DNS, TLS certificates, connectivity, routes, and firewall state — from the host's own view.
          </p>
        </div>
        <div class="rounded-2xl border border-brand-500/30 bg-brand-500/[0.04] p-7 transition hover:-translate-y-0.5 hover:border-brand-500/50">
          <div class="flex items-center justify-between">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-500/10 text-brand-300">
              <.icon name="hero-wrench-screwdriver" class="h-5 w-5" />
            </div>
            <.state_chip state={:pending} label="approval" />
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">Act — behind approval</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">
            Restart a unit, stop a runaway job, fail over, scale a service — each one gated on a
            human click.
          </p>
        </div>
      </div>

      <p class="mx-auto mt-12 max-w-2xl text-center text-sm text-zinc-500">
        Dozens of packs spanning Linux, databases, Kubernetes, and your cloud — install what you
        run, or author your own.
        <.link navigate={~p"/packs"} class="font-medium text-brand-300 hover:text-brand-200">
          Browse the catalog →
        </.link>
      </p>
    </div>
  </section>

  <%!-- Is it safe? — the persona's real worry, answered briefly. The full
       security model + the live incident live on home and /security. --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center lg:px-8">
      <h2 class="text-base font-semibold text-brand-400">But is it safe?</h2>
      <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
        Access means a gated catalog — not a shell.
      </p>
      <p class="mt-6 text-lg leading-relaxed text-zinc-400 text-pretty">
        Your AI can only call actions you've declared in a content-hashed pack — undeclared commands
        don't exist to it. Reads run free; anything that changes waits for your one-click approval.
        Secrets are redacted on the host, every call lands in a tamper-evident audit trail, and
        there's no SSH and no standing key for an AI — or an attacker — to leak.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <.link
          navigate={~p"/security"}
          class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          See the full security model <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
        <.link
          navigate={~p"/use-cases/csi-data-loss"}
          class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          Watch it handle a real incident <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- Built for teams — a compact signal; depth in docs --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">For teams</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Built for teams, ready for enterprise.
        </p>
      </div>

      <p class="mx-auto mt-6 max-w-2xl text-center text-lg leading-relaxed text-zinc-400">
        SSO with Okta, Google Workspace, or Keycloak plus SCIM directory sync; owner / admin /
        operator / viewer roles with per-member runner scopes; account-wide MFA; scoped, revocable
        keys per agent; gated runbooks; and every event streamed to your SIEM.
      </p>

      <div class="mt-14 flex flex-wrap justify-center gap-4">
        <.marketing_button variant={:secondary} navigate={~p"/docs/sso"} icon="hero-arrow-right">
          SSO &amp; directory sync
        </.marketing_button>
        <.marketing_button variant={:secondary} navigate={~p"/docs/teams-and-access"}>
          Teams &amp; access
        </.marketing_button>
      </div>
    </div>
  </section>

  <%!-- FAQ — visible accordion + the FAQPage JSON-LD share @ai_faqs --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-brand-400">FAQ</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          The questions you're already asking.
        </p>
      </div>

      <div class="mt-16 divide-y divide-zinc-900 overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between transition-colors hover:bg-zinc-900/30 px-8 py-6 text-base font-semibold text-zinc-50">
              {q}
              <.icon
                name="hero-chevron-down"
                class="h-5 w-5 shrink-0 text-zinc-500 transition duration-200 group-hover:text-zinc-300 group-open:rotate-180 group-open:text-brand-400"
              />
            </summary>
            <p class="px-8 pb-6 text-sm leading-relaxed text-zinc-400">{a}</p>
          </details>
        <% end %>
      </div>
    </div>
  </section>

  <.marketing_cta
    headline="Give your AI a safe key to production."
    subcopy="Install a runner, connect your LLM, and run your first policy-gated action in minutes. Free for three runners — no credit card."
    secondary_label="Read the quickstart"
    secondary_path={~p"/docs/quickstart"}
  />

  <.marketing_footer />
</div>
