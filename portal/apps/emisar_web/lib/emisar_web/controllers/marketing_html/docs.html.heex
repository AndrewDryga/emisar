<%!-- ============================================================
  Docs index — entry cards into deeper docs
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100">
  <.marketing_nav current_user={@current_user} current={:docs} />

  <%!-- Hero --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <p class="text-base font-semibold text-brand-400">Documentation</p>
      <.marketing_heading tag="h1" scale={:display} class="mt-2">
        Docs
      </.marketing_heading>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
        Install a runner, author packs, wire in an LLM. The full reference and example packs
        live in the <.external_link href="https://github.com/andrewdryga/emisar">GitHub repo</.external_link>.
      </p>
    </div>
  </section>

  <%!-- Cards, grouped by what the reader is trying to do --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <%= for {section, cards} <- [
        {"Get started",
         [
           {~p"/docs/quickstart", "hero-rocket-launch", "Quickstart",
            "Sign up, install a runner, run your first action in under five minutes."},
           {~p"/docs/connect-an-llm", "hero-puzzle-piece", "Connect an LLM",
            "Claude.ai and ChatGPT over remote MCP, or Claude Code, Claude Desktop, Cursor, Gemini CLI, and Codex CLI via the stdio bridge."}
         ]},
        {"Operate",
         [
           {~p"/docs/policies-and-approvals", "hero-scale", "Policies & approvals",
            "Risk-tier defaults, per-action overrides, human approvals, and revocable standing grants — control what runs."},
           {~p"/docs/runbooks", "hero-queue-list", "Runbooks",
            "Saved, versioned action sequences — policy-gated per step, readable by your LLM as playbooks."},
           {~p"/docs/teams-and-access", "hero-user-group", "Teams & access",
            "Roles, invitations, per-member runner scopes, account-wide MFA, sessions, and API key scopes."},
           {~p"/docs/sso", "hero-identification", "Single sign-on & directory sync",
            "Enterprise OIDC sign-in (Google Workspace, Okta, Keycloak) plus SCIM directory sync — offboarding revokes access automatically, with group-to-role mapping."},
           {~p"/docs/runners", "hero-server-stack", "Runner fleet",
            "Groups and labels, enrollment keys, pack credentials, updates, troubleshooting, and clean removal."},
           {~p"/docs/audit-and-siem", "hero-document-magnifying-glass", "Audit & SIEM",
            "What gets recorded, the dashboard view, NDJSON export with a read-only key, and the runner journal."}
         ]},
        {"Build packs",
         [
           {~p"/docs/action-packs", "hero-cube-transparent", "Pack reference",
            "Action YAML reference: declared args + validation, limits, redaction, side-effects, examples."},
           {~p"/docs/publishing-packs", "hero-arrow-up-tray", "Author your own pack",
            "Write, validate, install, and trust a pack you maintain — and when to propose one to the registry."}
         ]},
        {"Reference",
         [
           {~p"/docs/security-model", "hero-shield-check", "Security model",
            "Trust boundary, searchable cloud audit, hash-chained runner journal, redaction-before-egress."},
           {~p"/pricing", "hero-credit-card", "Hosting & plans",
            "The supported product is the hosted emisar control plane today; the source-available repo can be evaluated in your own environment. Plans and audit retention are on the pricing page."}
         ]}
      ] do %>
        <div class="mt-12 first:mt-0">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500">
            {section}
          </h2>
          <div class="mt-4 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            <%= for {href, icon, title, desc} <- cards do %>
              <.link
                href={href}
                class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-brand-500/50"
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
                  <.icon name={icon} class="h-6 w-6" />
                </div>
                <h3 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-brand-300">
                  {title}
                </h3>
                <p class="mt-2 text-sm text-zinc-400">{desc}</p>
                <p class="mt-4 text-sm font-semibold text-brand-300">
                  Read it <span aria-hidden="true">&rarr;</span>
                </p>
              </.link>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-3 rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 text-sm text-zinc-400">
        <span>
          Everything else — example packs, the runner source, and the full reference — lives in
          the repo.
        </span>
        <a
          href="https://github.com/andrewdryga/emisar"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 font-semibold text-brand-300 hover:text-brand-200"
        >
          Open on GitHub <.icon name="hero-arrow-top-right-on-square" class="h-3.5 w-3.5" />
        </a>
      </div>
    </div>
  </section>

  <%!-- Use cases --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-50 sm:text-4xl text-balance">
          Use cases
        </h2>
        <p class="mt-4 text-lg leading-8 text-zinc-400 text-pretty">
          Worked examples of letting an agent operate real infrastructure through declared,
          gated, audited actions — not a shell.
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-3">
        <%= for {title, desc, href} <- [
          {"Cassandra ops",
           "Triage a read-latency alert and run nodetool repair on the lagging keyspace, behind one approval.",
           ~p"/use-cases/cassandra-ops"},
          {"Postgres ops",
           "Check replication lag and slow queries, then terminate a blocking backend — with approval.",
           ~p"/use-cases/postgres-ops"},
          {"Incident response: the 33-hour wipe",
           "A CSI driver reformats a live volume; the agent contains it through declared actions and writes the fix to Terraform.",
           ~p"/use-cases/csi-data-loss"}
        ] do %>
          <.link
            navigate={href}
            class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 transition hover:border-brand-500/50"
          >
            <h3 class="text-base font-semibold text-zinc-50 group-hover:text-brand-300">
              {title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{desc}</p>
            <p class="mt-4 text-sm font-semibold text-brand-300">
              Read it <span aria-hidden="true">&rarr;</span>
            </p>
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Help CTA --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 text-center lg:px-8">
      <.marketing_heading tag="h2" scale={:section}>
        Stuck on something?
      </.marketing_heading>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-zinc-400">
        Open an issue on GitHub or email us. We answer fast.
      </p>
      <div class="mt-10 flex items-center justify-center gap-6">
        <.marketing_button
          external
          href="https://github.com/andrewdryga/emisar/issues"
          size={:lg}
          icon="hero-arrow-top-right-on-square"
        >
          Open an issue
        </.marketing_button>
        <a
          href="mailto:support@emisar.dev"
          class="text-sm font-semibold text-zinc-100 hover:text-brand-300"
        >
          Email support <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
