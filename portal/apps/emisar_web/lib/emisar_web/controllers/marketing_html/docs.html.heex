<%!-- ============================================================
  Docs index — entry cards into deeper docs
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100">
  <.marketing_nav current_user={@current_user} current={:docs} />

  <%!-- Hero --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="text-base font-semibold text-brand-400">Reference &amp; guides</p>
      <.marketing_heading tag="h1" scale={:display} class="mt-2">
        emisar documentation
      </.marketing_heading>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
        Install a runner, author packs, wire in an LLM — the reference is right here. The runner
        and the packs are Apache-2.0 open source, and the full source — control plane included — is
        <.external_link href="https://github.com/andrewdryga/emisar">on GitHub</.external_link>
        too.
      </p>
    </div>
  </section>

  <%!-- Cards, grouped by what the reader is trying to do --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <%!-- Docs whose feature isn't on every plan get a plan badge on their card,
           so the paywall is visible before the click. Keyed by href; only the
           plan-gated topics appear. --%>
      <% plan_tiers = %{"/docs/sso" => :team} %>
      <%= for {section, cards} <- [
        {"Get started",
         [
           {~p"/docs/quickstart", "hero-rocket-launch", "Quickstart",
            "Sign up, install a runner, run your first action in under five minutes."},
           {~p"/docs/connect-an-llm", "hero-puzzle-piece", "Connect an LLM",
            "Claude.ai and ChatGPT over remote MCP, or Claude Code, Claude Desktop, Cursor, Gemini CLI, Codex CLI, and Grok CLI via the stdio bridge."}
         ]},
        {"Operate",
         [
           {~p"/docs/deployment", "hero-clipboard-document-check", "Deploying in production",
            "From one runner to a governed fleet — reference architecture, a phased rollout, best practices by layer, worked examples, and a go-live checklist."},
           {~p"/docs/policies-and-approvals", "hero-scale", "Policies & approvals",
            "Risk-tier defaults, per-action overrides, human approvals, and revocable standing grants — control what runs."},
           {~p"/docs/runbooks", "hero-queue-list", "Runbooks",
            "Saved, versioned action sequences — policy-gated per step, readable by your LLM as playbooks."},
           {~p"/docs/teams-and-access", "hero-user-group", "Teams & access",
            "Roles, invitations, per-member runner scopes, account-wide MFA, sessions, and API key scopes."},
           {~p"/docs/sso", "hero-identification", "Single sign-on & directory sync",
            "OIDC sign-in (Team and Enterprise) with Google Workspace, Okta, Keycloak, plus Enterprise SCIM directory sync — offboarding revokes access automatically, with group-to-role mapping."},
           {~p"/docs/runners", "hero-server-stack", "Runner fleet",
            "Groups and labels, enrollment keys, pack credentials, updates, troubleshooting, and clean removal."},
           {~p"/docs/signed-dispatch", "hero-finger-print", "Signed dispatch",
            "Make a runner run only actions a real person signed in their MCP client — generate keys, configure both ends, and rotate or revoke them across a fleet."},
           {~p"/docs/audit-and-siem", "hero-document-magnifying-glass", "Audit & SIEM",
            "What gets recorded, the dashboard view, NDJSON export with a read-only key, and the runner journal."}
         ]},
        {"Build packs",
         [
           {~p"/docs/action-packs", "hero-cube-transparent", "Pack reference",
            "Action YAML reference: declared args + validation, limits, redaction, side-effects, examples."},
           {~p"/docs/publishing-packs", "hero-arrow-up-tray", "Author your own pack",
            "Write, validate, install, and trust a pack you maintain — and when to propose one to the registry."},
           {~p"/docs/pack-registry", "hero-server-stack", "Host your own registry",
            "Run a private pack registry on GCS, S3, or any static host with packctl — hash-pinned installs, air-gap friendly."}
         ]},
        {"Reference",
         [
           {~p"/docs/mcp-reference", "hero-code-bracket", "MCP reference",
            "The methods, parameters, idempotency, and error taxonomy of the emisar MCP server — the contract once you're connected."},
           {~p"/docs/security-model", "hero-shield-check", "Security model",
            "Trust boundary, searchable cloud audit, hash-chained runner journal, redaction-before-egress."},
           {~p"/pricing", "hero-credit-card", "Hosting & plans",
            "The supported product is the hosted emisar control plane today; the repo — Apache-2.0 runner and packs, source-available control plane — can be evaluated in your own environment. Plans and audit retention are on the pricing page."}
         ]}
      ] do %>
        <div class="mt-12 first:mt-0">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500">
            {section}
          </h2>
          <div class="mt-4 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
            <%= for {href, icon, title, desc} <- cards do %>
              <.link
                href={href}
                class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-brand-500/50"
              >
                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
                  <.icon name={icon} class="h-6 w-6" />
                </div>
                <div class="mt-6 flex flex-wrap items-center gap-x-2 gap-y-1.5">
                  <h3 class="text-xl font-semibold text-zinc-50 group-hover:text-brand-300">
                    {title}
                  </h3>
                  <.plan_note :if={plan_tiers[href]} tier={plan_tiers[href]} link={false} />
                </div>
                <p class="mt-2 text-sm text-zinc-400">{desc}</p>
                <p class="mt-4 text-sm font-semibold text-brand-300">
                  Read it
                  <span
                    aria-hidden="true"
                    class="inline-block transition-transform group-hover:translate-x-0.5"
                  >
                    &rarr;
                  </span>
                </p>
              </.link>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%!-- Guides --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-50 text-balance sm:text-4xl">
          Guides
        </h2>
        <p class="mt-4 text-lg leading-8 text-zinc-400 text-pretty">
          Practical guidance for giving AI agents production access without handing them a shell.
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 lg:grid-cols-2">
        <%= for guide <- @guides do %>
          <.link
            navigate={~p"/guides/#{guide.slug}"}
            class="group block rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition-colors hover:border-brand-500/40"
          >
            <p class="text-xs text-zinc-500">{guide.date} &middot; {guide.read_time}</p>
            <h3 class="mt-3 text-2xl font-bold tracking-tight text-white text-balance group-hover:text-brand-100">
              {guide.title}
            </h3>
            <p class="mt-3 text-base leading-relaxed text-zinc-400 text-pretty">{guide.dek}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-brand-400 group-hover:text-brand-300">
              Read the guide <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
            </span>
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Use cases --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-50 sm:text-4xl text-balance">
          Use cases
        </h2>
        <p class="mt-4 text-lg leading-8 text-zinc-400 text-pretty">
          Worked examples of letting an agent operate real infrastructure through declared,
          gated, audited actions — not a shell.
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-3xl grid-cols-1 gap-6 md:grid-cols-2">
        <%= for {title, desc, href} <- [
          {"Incident response: the 33-hour wipe",
           "A CSI driver reformats a live volume; the agent contains it through declared actions and writes the fix to Terraform.",
           ~p"/use-cases/csi-data-loss"},
          {"The fleet-wide 502",
           "Every backend was green, yet one anycast edge threw intermittent 502s; the agent traced it across five layers and stopped the bleed behind approvals.",
           ~p"/use-cases/ingress-502"}
        ] do %>
          <.link
            navigate={href}
            class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 transition hover:border-brand-500/50"
          >
            <h3 class="text-base font-semibold text-zinc-50 group-hover:text-brand-300">
              {title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{desc}</p>
            <p class="mt-4 text-sm font-semibold text-brand-300">
              Read it
              <span
                aria-hidden="true"
                class="inline-block transition-transform group-hover:translate-x-0.5"
              >
                &rarr;
              </span>
            </p>
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Help CTA --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 text-center lg:px-8">
      <.marketing_heading tag="h2" scale={:section}>
        Stuck on something?
      </.marketing_heading>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-zinc-400">
        Open an issue on GitHub or email us. We answer fast.
      </p>
      <div class="mt-10 flex items-center justify-center gap-6">
        <.marketing_button
          external
          href="https://github.com/andrewdryga/emisar/issues"
          size={:lg}
          icon="hero-arrow-top-right-on-square"
        >
          Open an issue
        </.marketing_button>
        <a
          href={EmisarWeb.MailTo.support()}
          class="text-sm font-semibold text-zinc-100 hover:text-brand-300"
        >
          Email support <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
