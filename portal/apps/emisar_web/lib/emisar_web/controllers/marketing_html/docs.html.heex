<%!-- ============================================================
  Docs index — entry cards into deeper docs
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100">
  <.marketing_nav current={:docs} />

  <%!-- Hero --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <p class="text-base font-semibold text-indigo-400">Documentation</p>
      <h1 class="mt-2 text-6xl font-bold tracking-tight text-zinc-50 md:text-7xl">
        Docs
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
        Install a runner, author packs, wire in an LLM. The full reference and example packs
        live in the <.external_link href="https://github.com/andrewdryga/emisar">GitHub repo</.external_link>.
      </p>
    </div>
  </section>

  <%!-- Cards --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <.link
          href={~p"/docs/quickstart"}
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-rocket-launch" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            Quickstart
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            Sign up, install a runner, run your first action in under five minutes.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            Read the guide <span aria-hidden="true">&rarr;</span>
          </p>
        </.link>

        <.link
          href={~p"/docs/action-packs"}
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-cube-transparent" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            Pack reference
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            Action YAML reference: declared args + validation, limits, redaction,
            side-effects, dispatch-form examples.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            See the spec <span aria-hidden="true">&rarr;</span>
          </p>
        </.link>

        <.link
          href={~p"/docs/publishing-packs"}
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-arrow-up-tray" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            Author your own pack
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            Write, validate, install, and trust a pack you maintain yourself — and when to propose
            a generic one to the curated registry.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            Author a pack <span aria-hidden="true">&rarr;</span>
          </p>
        </.link>

        <.link
          href={~p"/docs/security-model"}
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-shield-check" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            Security model
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            Trust boundary, searchable cloud audit, hash-chained runner journal, and
            redaction-before-egress.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            Read the model <span aria-hidden="true">&rarr;</span>
          </p>
        </.link>

        <.link
          href={~p"/docs/connect-an-llm"}
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-puzzle-piece" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            Connect an LLM
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            Wire emisar into Claude Code, Claude Desktop, Cursor, Gemini CLI, or Codex CLI.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            Set up MCP <span aria-hidden="true">&rarr;</span>
          </p>
        </.link>

        <.link
          href={~p"/pricing"}
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-server-stack" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            Hosting &amp; plans
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            The supported product is the hosted emisar control plane today; the source-available
            repository can be evaluated in your own environment. Plans and audit retention are on
            the pricing page.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            Plans &amp; self-host <span aria-hidden="true">&rarr;</span>
          </p>
        </.link>

        <a
          href="https://github.com/andrewdryga/emisar"
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:border-indigo-500/50"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-code-bracket" class="h-6 w-6" />
          </div>
          <h2 class="mt-6 text-xl font-semibold text-zinc-50 group-hover:text-indigo-300">
            GitHub repo
          </h2>
          <p class="mt-2 text-sm text-zinc-400">
            All the reference docs, example packs, and the runner source.
          </p>
          <p class="mt-4 text-sm font-semibold text-indigo-300">
            Open on GitHub <span aria-hidden="true">&rarr;</span>
          </p>
        </a>
      </div>
    </div>
  </section>

  <%!-- Use cases --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-50 sm:text-4xl">Use cases</h2>
        <p class="mt-4 text-lg leading-8 text-zinc-400">
          Worked examples of letting an agent operate real infrastructure through declared,
          gated, audited actions — not a shell.
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-3">
        <%= for {title, desc, href} <- [
          {"Cassandra ops",
           "Triage a read-latency alert and run nodetool repair on the lagging keyspace, behind one approval.",
           ~p"/use-cases/cassandra-ops"},
          {"Postgres ops",
           "Check replication lag and slow queries, then terminate a blocking backend — with approval.",
           ~p"/use-cases/postgres-ops"},
          {"Incident response: the 33-hour wipe",
           "A CSI driver reformats a live volume; the agent contains it through declared actions and writes the fix to Terraform.",
           ~p"/use-cases/csi-data-loss"}
        ] do %>
          <.link
            navigate={href}
            class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 transition hover:border-indigo-500/50"
          >
            <h3 class="text-base font-semibold text-zinc-50 group-hover:text-indigo-300">
              {title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{desc}</p>
            <p class="mt-4 text-sm font-semibold text-indigo-300">
              Read it <span aria-hidden="true">&rarr;</span>
            </p>
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Help CTA --%>
  <section class="border-t border-zinc-900 py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 text-center lg:px-8">
      <h2 class="text-4xl font-bold tracking-tight text-zinc-50 sm:text-5xl">
        Stuck on something?
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-zinc-400">
        Open an issue on GitHub or email us. We answer fast.
      </p>
      <div class="mt-10 flex items-center justify-center gap-6">
        <a
          href="https://github.com/andrewdryga/emisar/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-500 px-6 py-3 text-sm font-semibold text-zinc-950 hover:bg-indigo-400"
        >
          Open an issue <.icon name="hero-arrow-top-right-on-square" class="h-4 w-4" />
        </a>
        <a
          href="mailto:support@emisar.dev"
          class="text-sm font-semibold text-zinc-100 hover:text-indigo-300"
        >
          Email support <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
