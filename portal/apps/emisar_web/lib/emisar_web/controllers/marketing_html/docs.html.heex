<%!-- ============================================================
  Docs index — the map of the documentation tree
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100">
  <.marketing_nav current_user={@current_user} current={:docs} />

  <%!-- Hero --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="text-base font-semibold text-brand-400">Reference &amp; guides</p>
      <.marketing_heading tag="h1" scale={:display} class="mt-2">
        emisar documentation
      </.marketing_heading>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400">
        Install a runner, author packs, wire in an LLM — the reference is right here. The runner
        and the packs are Apache-2.0 open source, and the full source — control plane included — is
        <.external_link href="https://github.com/andrewdryga/emisar">on GitHub</.external_link>
        too.
      </p>
    </div>
  </section>

  <%!-- The docs tree, sourced from EmisarWeb.DocsNav so the index, the shell
       sidebar, and prev/next never drift. The first group (Get started) is the
       featured band; the rest render as dense grouped link lists. --%>
  <section class="pb-16 sm:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <% [{_get_started, featured} | rest_groups] = EmisarWeb.DocsNav.groups() %>
      <% last_index = length(rest_groups) - 1 %>

      <%!-- Start here: the two get-started pages, featured by SCALE (big icon
           tile, xl title) but on the same flush-left row grammar as every
           other section — the -mx/px pair cancels at rest, so the tile's left
           edge lands exactly on the eyebrow line like the group rows' icons. --%>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400">Start here</h2>
      <div class="mt-5 grid grid-cols-1 gap-x-8 gap-y-2 md:grid-cols-2">
        <.link
          :for={page <- featured}
          href={page.path}
          class="group -mx-4 flex items-start gap-4 rounded-xl px-4 py-4 transition-colors hover:bg-zinc-900/50"
        >
          <div class="flex h-12 w-12 flex-none items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name={page.icon} class="h-6 w-6" />
          </div>
          <div class="min-w-0">
            <h3 class="text-xl font-semibold text-zinc-50 group-hover:text-brand-300">
              {page.title}
            </h3>
            <p class="mt-1 text-sm leading-relaxed text-zinc-400">{page.desc}</p>
            <p class="mt-2 text-sm font-semibold text-brand-300">
              Read it
              <span
                aria-hidden="true"
                class="inline-block transition-transform group-hover:translate-x-0.5"
              >
                &rarr;
              </span>
            </p>
          </div>
        </.link>
      </div>

      <%!-- Everything else, dense: eyebrow + a two-column list of linked rows --%>
      <div :for={{{label, pages}, group_index} <- Enum.with_index(rest_groups)} class="mt-14">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400">{label}</h2>
        <div class="mt-5 grid gap-x-8 gap-y-1 md:grid-cols-2">
          <.link
            :for={page <- pages}
            href={page.path}
            class="group -mx-3 flex items-start gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-zinc-900/50"
          >
            <.icon name={page.icon} class="mt-0.5 h-5 w-5 flex-none text-brand-400/80" />
            <div>
              <span class="text-sm font-semibold text-zinc-50 group-hover:text-brand-300">
                {page.title}
              </span>
              <p class="mt-0.5 text-[13px] leading-snug text-zinc-500">{page.desc}</p>
            </div>
          </.link>

          <%!-- One extra, non-DocsNav row after Reference: hosting + plans. --%>
          <.link
            :if={group_index == last_index}
            href="/pricing"
            class="group -mx-3 flex items-start gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-zinc-900/50"
          >
            <.icon name="hero-credit-card" class="mt-0.5 h-5 w-5 flex-none text-brand-400/80" />
            <div>
              <span class="text-sm font-semibold text-zinc-50 group-hover:text-brand-300">
                Hosting &amp; plans
              </span>
              <p class="mt-0.5 text-[13px] leading-snug text-zinc-500">
                The supported product is the hosted emisar control plane today; plans and audit
                retention are on the pricing page.
              </p>
            </div>
          </.link>
        </div>
      </div>
    </div>
  </section>

  <%!-- Guides --%>
  <section class="border-t border-zinc-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-50 text-balance sm:text-4xl">
          Guides
        </h2>
        <p class="mt-4 text-lg leading-8 text-zinc-400 text-pretty">
          Practical guidance for giving AI agents production access without handing them a shell.
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 lg:grid-cols-2">
        <%= for guide <- @guides do %>
          <.link
            navigate={~p"/guides/#{guide.slug}"}
            class="group block rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition-colors hover:border-brand-500/40"
          >
            <p class="text-xs text-zinc-400">{guide.date} &middot; {guide.read_time}</p>
            <h3 class="mt-3 text-2xl font-bold tracking-tight text-white text-balance group-hover:text-brand-100">
              {guide.title}
            </h3>
            <p class="mt-3 text-base leading-relaxed text-zinc-400 text-pretty">{guide.dek}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-brand-400 group-hover:text-brand-300">
              Read the guide <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
            </span>
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Use cases --%>
  <section class="border-t border-zinc-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-50 sm:text-4xl text-balance">
          Use cases
        </h2>
        <p class="mt-4 text-lg leading-8 text-zinc-400 text-pretty">
          Worked examples of letting an agent operate real infrastructure through declared,
          gated, audited actions — not a shell.
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-3xl grid-cols-1 gap-6 md:grid-cols-2">
        <%= for {title, desc, href} <- [
          {"Incident response: the 33-hour wipe",
           "A CSI driver reformats a live volume; the agent contains it through declared actions and writes the fix to Terraform.",
           ~p"/use-cases/csi-data-loss"},
          {"The fleet-wide 502",
           "Every backend was green, yet one anycast edge threw intermittent 502s; the agent traced it across five layers and stopped the bleed behind approvals.",
           ~p"/use-cases/ingress-502"}
        ] do %>
          <.link
            navigate={href}
            class="group rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 transition hover:border-brand-500/50"
          >
            <h3 class="text-base font-semibold text-zinc-50 group-hover:text-brand-300">
              {title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{desc}</p>
            <p class="mt-4 text-sm font-semibold text-brand-300">
              Read it
              <span
                aria-hidden="true"
                class="inline-block transition-transform group-hover:translate-x-0.5"
              >
                &rarr;
              </span>
            </p>
          </.link>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Help CTA --%>
  <section class="border-t border-zinc-900 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-6 text-center lg:px-8">
      <.marketing_heading tag="h2" scale={:section}>
        Stuck on something?
      </.marketing_heading>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-zinc-400">
        Open an issue on GitHub or email us. We answer fast.
      </p>
      <div class="mt-10 flex items-center justify-center gap-6">
        <.marketing_button
          external
          href="https://github.com/andrewdryga/emisar/issues"
          size={:lg}
          icon="hero-arrow-top-right-on-square"
        >
          Open an issue
        </.marketing_button>
        <a
          href={EmisarWeb.MailTo.support()}
          class="text-sm font-semibold text-zinc-100 hover:text-brand-300"
        >
          Email support <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
