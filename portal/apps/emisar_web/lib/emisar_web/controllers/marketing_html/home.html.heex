      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Free</h3>
          <p class="mt-2 text-sm text-zinc-400">For homelab and tinkering.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$0</span>
            <span class="text-sm text-zinc-500">/ forever</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" /> 3 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" /> 1 user
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              7-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Community support
            </li>
          </ul>
        </div>
        <div class="relative rounded-2xl border-2 border-indigo-500/60 bg-zinc-950/80 p-8 shadow-2xl shadow-indigo-950/40">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-indigo-500 px-3 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-zinc-950">
            Most popular
          </span>
          <h3 class="text-lg font-semibold text-white">Team</h3>
          <p class="mt-2 text-sm text-zinc-400">For teams running real production.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$20</span>
            <span class="text-sm text-zinc-500">/ runner / month</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Up to 100 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Unlimited users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              90-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Monthly invoices, email support
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Enterprise</h3>
          <p class="mt-2 text-sm text-zinc-400">For regulated environments &amp; fleets.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">Custom</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Unlimited runners &amp; users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              365-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Security and procurement review
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Design-partner deployment planning
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 flex justify-center">
        <.link
          href={~p"/pricing"}
          class="inline-flex items-center gap-2 rounded-lg bg-transparent px-5 py-2.5 text-sm font-semibold text-zinc-100 ring-1 ring-zinc-800 hover:ring-zinc-700"
        >
          Compare all plans <.icon name="hero-arrow-right" class="h-4 w-4" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- FAQ --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-indigo-400">FAQ</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The skeptical questions, answered.
        </p>
      </div>

      <div class="mt-16 divide-y divide-zinc-900 rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between px-8 py-6 text-base font-semibold text-white">
              {q}
              <.icon name="hero-plus" class="h-5 w-5 text-zinc-500 transition group-open:hidden" />
              <.icon name="hero-minus" class="hidden h-5 w-5 text-indigo-400 group-open:block" />
            </summary>
            <p class="px-8 pb-6 text-sm text-zinc-400 leading-relaxed">{a}</p>
          </details>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Final CTA --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="overflow-hidden rounded-lg border border-indigo-500/30 bg-zinc-950 p-12 sm:p-16">
        <div class="text-center">
          <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
            Sleep tonight. Sign up free.
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-lg text-zinc-400 leading-relaxed">
            Three runners. Seven-day audit. No credit card. Read the quickstart and
            ship your first policy-gated LLM action.
          </p>
          <form
            action={~p"/sign_up"}
            method="get"
            class="mx-auto mt-10 flex max-w-md flex-col items-center gap-3 sm:flex-row"
          >
            <label for="cta-email" class="sr-only">Work email</label>
            <input
              type="email"
              name="email"
              id="cta-email"
              placeholder="you@company.com"
              class="w-full rounded-lg border-0 bg-zinc-900/80 px-4 py-2.5 text-sm text-white ring-1 ring-zinc-800 placeholder:text-zinc-500 focus:ring-2 focus:ring-indigo-500"
            />
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 whitespace-nowrap rounded-lg bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-indigo-400 sm:w-auto"
            >
              Start free <.icon name="hero-arrow-right" class="h-4 w-4" />
            </button>
          </form>
          <p class="mt-4 text-xs text-zinc-400">
            No credit card. Cancel anytime. Your audit log is yours to export.
          </p>
        </div>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
