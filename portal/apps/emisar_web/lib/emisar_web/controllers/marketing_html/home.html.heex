<%!-- ============================================================
  Home — emisar marketing landing
  Give your LLM safe access to production. Without the panic.
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100 antialiased selection:bg-indigo-500/30">
  <.marketing_nav current={:home} sticky />

  <%!-- Hero --%>
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 -top-40 -z-10 transform-gpu blur-3xl"
    >
      <div
        class="mx-auto aspect-[1155/678] w-[72rem] bg-gradient-to-tr from-indigo-600 to-indigo-900 opacity-20"
        style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"
      >
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-6 pt-20 pb-16 sm:pt-28 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-8 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-4 py-1 text-xs font-semibold text-indigo-300">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75">
            </span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-indigo-400"></span>
          </span>
          Private beta
        </p>
        <h1 class="text-5xl font-bold tracking-tight text-white sm:text-7xl">
          Give AI tools approved infrastructure actions, not SSH.
        </h1>
        <p class="mx-auto mt-8 max-w-2xl text-lg text-zinc-400 leading-relaxed">
          emisar is a versioned, policy-gated action catalog for AI agents. Your DevOps team
          declares exactly which operations the model can run. Every invocation is validated,
          streamed, and recorded to an append-only audit log.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <.link
            href={~p"/sign_up"}
            class="inline-flex items-center gap-2 whitespace-nowrap rounded-lg bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-indigo-400"
          >
            Start free <.icon name="hero-arrow-right" class="h-4 w-4" />
          </.link>
          <.link
            href={~p"/security"}
            class="inline-flex items-center gap-2 whitespace-nowrap rounded-lg bg-transparent px-5 py-2.5 text-sm font-semibold text-zinc-100 ring-1 ring-zinc-800 hover:ring-zinc-700"
          >
            Read the security model
          </.link>
        </div>
        <p class="mt-6 text-xs text-zinc-500">
          Free forever for 3 runners &middot; No credit card &middot;
          <.link
            href={~p"/docs/quickstart"}
            class="text-zinc-400 underline-offset-2 hover:text-zinc-200 hover:underline"
          >
            Read the quickstart
          </.link>
        </p>
      </div>

      <%!-- Live terminal mock --%>
      <div class="mx-auto mt-16 max-w-3xl rounded-xl border border-zinc-900 bg-black/60 shadow-2xl shadow-indigo-950/30">
        <div class="flex items-center gap-2 border-b border-zinc-900 px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
          <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          <span class="ml-3 font-mono text-xs text-zinc-500">sre@prod-cassandra-01: ~</span>
        </div>
        <pre class="overflow-x-auto p-6 font-mono text-xs leading-6 text-zinc-300"><span class="text-zinc-500"># Install on a Linux or macOS host</span>
<span class="text-indigo-400">$</span> curl -sSL https://emisar.dev/install.sh | sudo EMISAR_AUTH_KEY=emkey-auth-*** bash
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">downloading emisar-v0.2.0-linux-amd64.tar.gz</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">verifying checksum</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">creating system user emisar</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">writing default config to /etc/emisar/config.yaml</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">installing binary to /usr/local/bin/emisar</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">installed: emisar <span class="text-emerald-400">v0.2.0</span></span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">copying example packs to /etc/emisar/packs</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">writing /etc/systemd/system/emisar.service</span>
<span class="text-indigo-400">[install]</span> <span class="text-zinc-400">starting emisar.service</span>

<span class="text-zinc-500">→ Open <span class="text-emerald-400">app.emisar.dev/runners</span> — the host is online and advertising 6 actions.</span></pre>
      </div>
    </div>
  </section>

  <%!-- Pain section --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">The status quo</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Today, your AI agent is either:
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Three patterns. All three are worse than the alternative they replaced.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:max-w-none lg:grid-cols-3">
        <div class="rounded-2xl border border-red-900/40 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-red-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-500/10 text-red-400">
            <.icon name="hero-command-line" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Given a raw SSH key</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Full shell on prod. The model is "creative." Last Tuesday it ran
            <code class="rounded bg-zinc-900 px-1 py-0.5 text-xs text-red-300">
              rm&nbsp;-rf&nbsp;/var/lib/postgresql
            </code>
            to "free up disk space." There's no record of why. There's no record at all.
          </p>
        </div>
        <div class="rounded-2xl border border-amber-900/40 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-amber-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
            <.icon name="hero-puzzle-piece" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Wired to a bespoke tool server</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Two engineers built a custom MCP server in a weekend. It hardcodes one cluster,
            swallows stderr, has no approval flow, and lives in a repo nobody dares touch.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-500/10 text-zinc-400">
            <.icon name="hero-chat-bubble-left-right" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Asked to "/runbook" in Slack</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Twenty-three slash commands, three owners, two of whom left in 2024.
            Write-only output, lost in channel scrollback, and the audit trail is whatever
            you remember from the postmortem at 3 a.m.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%!-- How it works --%>
  <section class="border-y border-zinc-900 bg-gradient-to-b from-zinc-950 via-zinc-950/40 to-zinc-950 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">How emisar works</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          A single path from declared YAML to signed audit log.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          No long-lived shells, no hidden tools, no surprise side effects. Every step is
          observable. Every step is reversible at the policy layer.
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-6xl">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-5">
          <%= for {step, title, desc, icon} <- [
            {"01", "DevOps publishes pack", "Actions declared as YAML. Versioned in git. Content-addressed and shipped with the runner.", "hero-document-text"},
            {"02", "Runner advertises", "On boot, the runner reports its action manifest to the control plane over outbound TLS.", "hero-signal"},
            {"03", "LLM calls MCP tool", "Your model sees only what you declared. Args are validated server-side against the declared argument schema.", "hero-cpu-chip"},
            {"04", "Policy evaluates", "Allow, deny, or page an approver. Decision is recorded before any side effect.", "hero-shield-check"},
            {"05", "Audit + stream", "stdout, stderr, exit code, redactions — appended to a JSONL audit on the host and synced to the cloud.", "hero-document-check"}
          ] do %>
            <div class="group relative rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 transition hover:-translate-y-0.5 hover:border-indigo-500/40">
              <div class="flex items-center justify-between">
                <span class="font-mono text-xs font-semibold text-indigo-400">{step}</span>
                <.icon
                  name={icon}
                  class="h-5 w-5 text-zinc-600 transition group-hover:text-indigo-400"
                />
              </div>
              <h3 class="mt-6 text-base font-semibold text-white">{title}</h3>
              <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{desc}</p>
            </div>
          <% end %>
        </div>
        <div class="mt-6 hidden items-center justify-between px-8 text-zinc-700 md:flex">
          <span class="font-mono text-xs">pack.yaml</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">register</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">tools/call</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">policy.eval</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">journal.append</span>
        </div>
      </div>
    </div>
  </section>

  <%!-- Action catalog example --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">The action contract</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          One YAML file. One source of truth.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          This is what an LLM sees when it calls <code class="font-mono text-indigo-300">cassandra.nodetool_repair</code>.
          Nothing more. The runner refuses anything not in this catalog.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl rounded-xl border border-zinc-900 bg-black/60 shadow-2xl shadow-indigo-950/20">
        <div class="flex items-center gap-2 border-b border-zinc-900 px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
          <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          <span class="ml-3 font-mono text-xs text-zinc-500">
            packs/cassandra/actions/nodetool_repair.yaml
          </span>
        </div>
        <pre class="overflow-x-auto p-6 font-mono text-xs leading-6 text-zinc-300"><span class="text-zinc-500">## Trigger a primary-range repair on a single Cassandra node.</span>
<span class="text-indigo-300">schema_version</span>: <span class="text-amber-300">1</span>
<span class="text-indigo-300">id</span>: cassandra.nodetool_repair
<span class="text-indigo-300">title</span>: <span class="text-emerald-300">"Cassandra repair"</span>
<span class="text-indigo-300">kind</span>: exec
<span class="text-indigo-300">risk</span>: <span class="text-amber-300">high</span>            <span class="text-zinc-500"># forces policy to require_approval by default</span>

<span class="text-indigo-300">args</span>:
  - <span class="text-indigo-300">name</span>: keyspace
    <span class="text-indigo-300">type</span>: string
    <span class="text-indigo-300">required</span>: <span class="text-amber-300">true</span>
    <span class="text-indigo-300">validation</span>:
      <span class="text-indigo-300">pattern</span>: <span class="text-emerald-300">"^[a-z][a-z0-9_]&#123;0,47&#125;$"</span>
  - <span class="text-indigo-300">name</span>: parallelism
    <span class="text-indigo-300">type</span>: string
    <span class="text-indigo-300">default</span>: <span class="text-emerald-300">sequential</span>
    <span class="text-indigo-300">validation</span>:
      <span class="text-indigo-300">enum</span>: [<span class="text-emerald-300">sequential</span>, <span class="text-emerald-300">parallel</span>, <span class="text-emerald-300">dc_parallel</span>]

<span class="text-indigo-300">execution</span>:
  <span class="text-indigo-300">command</span>:
    <span class="text-indigo-300">binary</span>: /usr/bin/nodetool
    <span class="text-indigo-300">argv</span>:
      - <span class="text-emerald-300">"repair"</span>
      - <span class="text-emerald-300">"&#123;&#123; args.keyspace &#125;&#125;"</span>
  <span class="text-indigo-300">timeout</span>: 6h
  <span class="text-indigo-300">cancel_grace</span>: 5m

<span class="text-indigo-300">output</span>:
  <span class="text-indigo-300">parser</span>: text
  <span class="text-indigo-300">max_stdout_bytes</span>: <span class="text-amber-300">4194304</span>
  <span class="text-indigo-300">max_stderr_bytes</span>: <span class="text-amber-300">262144</span>

<span class="text-indigo-300">redact</span>:
  - <span class="text-indigo-300">name</span>: password
    <span class="text-indigo-300">type</span>: regex
    <span class="text-indigo-300">pattern</span>: <span class="text-emerald-300">'(?i)password\s*=\s*\S+'</span>
  - <span class="text-indigo-300">name</span>: aws_access_key
    <span class="text-indigo-300">type</span>: regex
    <span class="text-indigo-300">pattern</span>: <span class="text-emerald-300">'AKIA[0-9A-Z]&#123;16&#125;'</span></pre>
      </div>
      <p class="mx-auto mt-6 max-w-2xl text-center text-sm text-zinc-500">
        This is the contract. The LLM sees only what you declare; your SRE sees every invocation.
      </p>
    </div>
  </section>

  <%!-- Three-pillar deep-dive --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Three pillars</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          A catalog, a gate, and a ledger.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Borrow what's safe about deploys: code review, policy as code, immutable history.
          Apply it to every operational command an LLM is allowed to issue.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-7xl grid-cols-1 gap-8 lg:grid-cols-3">
        <%!-- Pillar 1: Catalog --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-cube-transparent" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Versioned action catalog</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Packs live in git. Each pack is content-addressed. The runner refuses anything
            outside the manifest. No more Slack-bot whack-a-mole.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              packs/linux-core/actions/systemctl_status.yaml
            </div>
            <pre class="p-3 font-mono text-[11px] leading-5 text-zinc-300"><span class="text-indigo-300">schema_version</span>: <span class="text-amber-300">1</span>
<span class="text-indigo-300">id</span>: linux.systemctl_status
<span class="text-indigo-300">title</span>: <span class="text-emerald-300">"Systemd unit status"</span>
<span class="text-indigo-300">kind</span>: exec
<span class="text-indigo-300">risk</span>: <span class="text-amber-300">low</span>
<span class="text-indigo-300">args</span>:
  - <span class="text-indigo-300">name</span>: unit
    <span class="text-indigo-300">type</span>: string
    <span class="text-indigo-300">required</span>: <span class="text-amber-300">true</span>
    <span class="text-indigo-300">validation</span>:
      <span class="text-indigo-300">enum</span>: [<span class="text-emerald-300">cassandra</span>, <span class="text-emerald-300">nginx</span>, <span class="text-emerald-300">postgresql</span>, <span class="text-emerald-300">docker</span>]
<span class="text-indigo-300">execution</span>:
  <span class="text-indigo-300">command</span>:
    <span class="text-indigo-300">binary</span>: /bin/systemctl
    <span class="text-indigo-300">argv</span>: [<span class="text-emerald-300">"status"</span>, <span class="text-emerald-300">"&#123;&#123; args.unit &#125;&#125;"</span>, <span class="text-emerald-300">"--no-pager"</span>]</pre>
          </div>
        </div>

        <%!-- Pillar 2: Policy --%>
        <div class="rounded-2xl border border-indigo-500/30 bg-zinc-950/60 p-8 ring-1 ring-indigo-500/10">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-shield-check" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Policy &amp; approval</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Rules per actor and action. Risky calls page a human. The model
            cannot bypass the gate &mdash; it can only wait.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              default policy
            </div>
            <pre class="p-3 font-mono text-[11px] leading-5 text-zinc-300"><span class="text-emerald-400">allow</span>:
  - <span class="text-indigo-300">name</span>: <span class="text-emerald-300">low-medium-ok</span>
    <span class="text-indigo-300">max_risk</span>: medium
<span class="text-amber-300">require_approval</span>:
  - <span class="text-indigo-300">name</span>: <span class="text-emerald-300">approve-high</span>
    <span class="text-indigo-300">risk</span>: high
    <span class="text-zinc-500"># Anything not matching above
      is denied by default.</span></pre>
          </div>
        </div>

        <%!-- Pillar 3: Audit --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-document-check" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Hash-chained audit</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Every input, output, exit code, redaction. SHA-256-chained JSONL on the
            host — any tampered or removed line is detected by <code class="text-zinc-300">emisar audit verify</code>. Mirrored to the
            cloud dashboard for review.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              app.emisar.dev / audit
            </div>
            <table class="w-full font-mono text-[11px] text-zinc-300">
              <thead class="bg-zinc-950/80 text-zinc-500">
                <tr>
                  <th class="px-3 py-2 text-left font-normal">time</th>
                  <th class="px-3 py-2 text-left font-normal">actor</th>
                  <th class="px-3 py-2 text-left font-normal">action</th>
                  <th class="px-3 py-2 text-left font-normal">status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-900">
                <tr>
                  <td class="px-3 py-2">14:02:18</td>
                  <td class="px-3 py-2 text-indigo-300">claude-3.7</td>
                  <td class="px-3 py-2">cassandra.nodetool_status</td>
                  <td class="px-3 py-2">
                    <span class="rounded bg-emerald-500/10 px-1.5 py-0.5 text-emerald-300">
                      ok
                    </span>
                  </td>
                </tr>
                <tr>
                  <td class="px-3 py-2">14:01:55</td>
                  <td class="px-3 py-2 text-indigo-300">claude-3.7</td>
                  <td class="px-3 py-2">cassandra.nodetool_repair</td>
                  <td class="px-3 py-2">
                    <span class="rounded bg-amber-500/10 px-1.5 py-0.5 text-amber-300">
                      approval
                    </span>
                  </td>
                </tr>
                <tr>
                  <td class="px-3 py-2">13:58:01</td>
                  <td class="px-3 py-2 text-indigo-300">claude-3.7</td>
                  <td class="px-3 py-2">linux.systemctl_status</td>
                  <td class="px-3 py-2">
                    <span class="rounded bg-emerald-500/10 px-1.5 py-0.5 text-emerald-300">
                      ok
                    </span>
                  </td>
                </tr>
                <tr>
                  <td class="px-3 py-2">13:52:44</td>
                  <td class="px-3 py-2 text-indigo-300">claude-3.7</td>
                  <td class="px-3 py-2">linux.tail_log</td>
                  <td class="px-3 py-2">
                    <span class="rounded bg-red-500/10 px-1.5 py-0.5 text-red-300">denied</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- Use cases --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">What teams ship with emisar</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Real ops, on real production, by real agents.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:max-w-none lg:grid-cols-4">
        <%= for {tag, title, scenario, icon, href} <- [
          {"cassandra", "Cassandra ops", "Agent triages a slow read latency alert by running nodetool.status, then proposes nodetool.repair on the lagging keyspace — pending one approver click.", "hero-circle-stack", ~p"/use-cases/cassandra-ops"},
          {"postgres", "Postgres ops", "Replication lag spikes overnight. The model runs pg.replication_lag, kills the offending slow query, then opens a follow-up ticket with the EXPLAIN plan attached.", "hero-server-stack", ~p"/use-cases/postgres-ops"},
          {"k8s", "K8s troubleshoot", "Pod is CrashLoopBackOff. Agent fetches logs and a describe via the kubectl pack. Restarting the deployment requires an approver — and a one-line justification.", "hero-cube", nil},
          {"incident", "Incident response", "Pager fires at 02:14. Agent executes the approved 'database failover' runbook step-by-step, pausing at each gate so the human can stay in the loop, not in the keyboard.", "hero-bell-alert", nil}
        ] do %>
          <div class="group flex flex-col rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-indigo-500/40">
            <div class="flex items-center justify-between">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
                <.icon name={icon} class="h-5 w-5" />
              </div>
              <span class="font-mono text-[10px] uppercase tracking-widest text-zinc-600">
                {tag}
              </span>
            </div>
            <h3 class="mt-6 text-lg font-semibold text-white">{title}</h3>
            <p class="mt-3 text-sm text-zinc-400 leading-relaxed">{scenario}</p>
            <.link
              :if={href}
              navigate={href}
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-indigo-400 hover:text-indigo-300"
            >
              Read the playbook <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
            </.link>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Comparison table --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Why not just&hellip;</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The alternatives, honestly.
        </p>
      </div>

      <div class="mx-auto mt-16 overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-zinc-900 text-xs uppercase tracking-wider text-zinc-500">
                <th class="px-6 py-4 font-medium"></th>
                <th class="px-6 py-4 font-semibold text-indigo-300">emisar</th>
                <th class="px-6 py-4 font-medium">Raw SSH key</th>
                <th class="px-6 py-4 font-medium">Code Interpreter</th>
                <th class="px-6 py-4 font-medium">Custom MCP server</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-900 text-zinc-300">
              <%= for {row, em, ssh, ci, mcp} <- [
                {"Append-only audit log", "yes", "no", "no", "maybe"},
                {"Policy as code", "yes", "no", "no", "maybe"},
                {"Approval workflow", "yes", "no", "no", "no"},
                {"Multi-host fleet", "yes", "maybe", "no", "no"},
                {"Streaming stdout/stderr", "yes", "yes", "no", "maybe"},
                {"On-prem control plane", "yes", "yes", "no", "yes"},
                {"Setup time", "5 min", "instant + nightmares", "30 sec", "1-2 weeks"}
              ] do %>
                <tr class="hover:bg-zinc-900/30">
                  <td class="px-6 py-4 font-medium text-zinc-100">{row}</td>
                  <td class="px-6 py-4">
                    <%= cond do %>
                      <% em == "yes" -> %>
                        <span class="inline-flex items-center gap-1.5 text-emerald-300">
                          <.icon name="hero-check-circle" class="h-4 w-4" />{if row ==
                                                                                  "Setup time",
                                                                                do: em,
                                                                                else: "Yes"}
                        </span>
                      <% true -> %>
                        {em}
                    <% end %>
                  </td>
                  <%= for v <- [ssh, ci, mcp] do %>
                    <td class="px-6 py-4">
                      <%= cond do %>
                        <% v == "yes" -> %>
                          <span class="inline-flex items-center gap-1.5 text-emerald-400/80">
                            <.icon name="hero-check" class="h-4 w-4" />Yes
                          </span>
                        <% v == "no" -> %>
                          <span class="inline-flex items-center gap-1.5 text-zinc-600">
                            <.icon name="hero-x-mark" class="h-4 w-4" />No
                          </span>
                        <% v == "maybe" -> %>
                          <span class="inline-flex items-center gap-1.5 text-amber-400/70">
                            <.icon name="hero-minus" class="h-4 w-4" />Partial
                          </span>
                        <% true -> %>
                          <span class="text-zinc-400">{v}</span>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <p class="mt-8 text-center">
        <.link
          navigate={~p"/compare/raw-ssh-for-ai"}
          class="inline-flex items-center gap-1 text-sm font-medium text-indigo-400 hover:text-indigo-300"
        >
          Read the full SSH-for-AI comparison
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </p>
    </div>
  </section>

  <%!-- Pricing teaser --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Pricing</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Pay per runner. Not per seat.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Free forever for tinkering. $20/runner/month when you go to prod. Unlimited users on every plan.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Free</h3>
          <p class="mt-2 text-sm text-zinc-400">For homelab and tinkering.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$0</span>
            <span class="text-sm text-zinc-500">/ forever</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" /> 3 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" /> 1 user
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              7-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Community support
            </li>
          </ul>
        </div>
        <div class="relative rounded-2xl border-2 border-indigo-500/60 bg-zinc-950/80 p-8 shadow-2xl shadow-indigo-950/40">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-indigo-500 px-3 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-zinc-950">
            Most popular
          </span>
          <h3 class="text-lg font-semibold text-white">Team</h3>
          <p class="mt-2 text-sm text-zinc-400">For teams running real production.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$20</span>
            <span class="text-sm text-zinc-500">/ runner / month</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Up to 100 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Unlimited users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              90-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Monthly invoices, email support
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Enterprise</h3>
          <p class="mt-2 text-sm text-zinc-400">For regulated environments &amp; fleets.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">Custom</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Unlimited runners &amp; users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Enterprise SSO &mdash; contact us
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              365-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              SLA &amp; dedicated Slack channel
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 flex justify-center">
        <.link
          href={~p"/pricing"}
          class="inline-flex items-center gap-2 rounded-lg bg-transparent px-5 py-2.5 text-sm font-semibold text-zinc-100 ring-1 ring-zinc-800 hover:ring-zinc-700"
        >
          Compare all plans <.icon name="hero-arrow-right" class="h-4 w-4" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- FAQ --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-indigo-400">FAQ</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The skeptical questions, answered.
        </p>
      </div>

      <div class="mt-16 divide-y divide-zinc-900 rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between px-8 py-6 text-base font-semibold text-white">
              {q}
              <.icon name="hero-plus" class="h-5 w-5 text-zinc-500 transition group-open:hidden" />
              <.icon name="hero-minus" class="hidden h-5 w-5 text-indigo-400 group-open:block" />
            </summary>
            <p class="px-8 pb-6 text-sm text-zinc-400 leading-relaxed">{a}</p>
          </details>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Final CTA --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl border border-indigo-500/30 bg-gradient-to-br from-indigo-600/20 via-zinc-950 to-zinc-950 p-12 sm:p-16">
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-indigo-500/20 blur-3xl"
        >
        </div>
        <div class="relative text-center">
          <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
            Sleep tonight. Sign up free.
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-lg text-zinc-400 leading-relaxed">
            Three runners. Seven-day audit. No credit card. Read the quickstart and
            ship your first policy-gated LLM action.
          </p>
          <form
            action={~p"/sign_up"}
            method="get"
            class="mx-auto mt-10 flex max-w-md flex-col items-center gap-3 sm:flex-row"
          >
            <label for="cta-email" class="sr-only">Work email</label>
            <input
              type="email"
              name="email"
              id="cta-email"
              placeholder="you@company.com"
              class="w-full rounded-lg border-0 bg-zinc-900/80 px-4 py-2.5 text-sm text-white ring-1 ring-zinc-800 placeholder:text-zinc-500 focus:ring-2 focus:ring-indigo-500"
            />
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 whitespace-nowrap rounded-lg bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-zinc-950 hover:bg-indigo-400 sm:w-auto"
            >
              Start free <.icon name="hero-arrow-right" class="h-4 w-4" />
            </button>
          </form>
          <p class="mt-4 text-xs text-zinc-500">
            No credit card. Cancel anytime. Your audit log is yours to export.
          </p>
        </div>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
