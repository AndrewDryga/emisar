<%!-- ============================================================
  Home — emisar marketing landing
  Give your LLM safe access to production. Without the panic.
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100 antialiased selection:bg-indigo-500/30">
  <.marketing_nav current_user={@current_user} current={:home} sticky />

  <%!-- Hero --%>
  <section class="relative flex min-h-[600px] items-center overflow-hidden border-b border-zinc-900 bg-zinc-950">
    <div class="hero-grid absolute inset-0" aria-hidden="true"></div>
    <div class="hero-glow absolute inset-0" aria-hidden="true"></div>

    <div class="relative mx-auto w-full max-w-7xl px-6 py-24 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-8 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-zinc-950/80 px-4 py-1 text-xs font-semibold text-indigo-300">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75">
            </span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-indigo-400"></span>
          </span>
          Public beta
        </p>
        <.marketing_heading tag="h1" scale={:display}>
          Give AI tools approved infrastructure actions, not SSH.
        </.marketing_heading>
        <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-zinc-300">
          Connect Claude, ChatGPT, Cursor, or any MCP client to a finite action catalog,
          enforced on-host with pack trust, policy gates, human approvals, a searchable audit
          trail, and a hash-chained runner journal.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <.marketing_button href={~p"/sign_up"} icon="hero-arrow-right">
            Start free
          </.marketing_button>
          <.marketing_button variant={:secondary} href={~p"/docs/quickstart"}>
            Run the quickstart
          </.marketing_button>
        </div>
        <p class="mt-6 text-xs text-zinc-400">
          Free for 3 runners &middot; No credit card &middot;
          <a
            href="https://github.com/andrewdryga/emisar/blob/main/LICENSE.md"
            target="_blank"
            rel="noopener noreferrer"
            class="underline-offset-2 hover:text-zinc-200 hover:underline"
          >
            Source-available license
          </a>
        </p>
      </div>
    </div>
  </section>

  <%!-- Pain section --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">The status quo</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Today, your AI agent is either:
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Three patterns. All three are worse than the alternative they replaced.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:max-w-none lg:grid-cols-3">
        <div class="rounded-2xl border border-red-900/40 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-red-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-500/10 text-red-400">
            <.icon name="hero-command-line" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Given a raw SSH key</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Full shell on prod. The model is "creative." A malformed request can become
            <code class="rounded bg-zinc-900 px-1 py-0.5 text-xs text-red-300">
              rm&nbsp;-rf&nbsp;/var/lib/postgresql
            </code>
            with no policy gate and no durable record of why it happened.
          </p>
        </div>
        <div class="rounded-2xl border border-amber-900/40 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-amber-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
            <.icon name="hero-puzzle-piece" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Wired to a bespoke tool server</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Two engineers built a custom MCP server in a weekend. It hardcodes one cluster,
            swallows stderr, has no approval flow, and lives in a repo nobody dares touch.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-500/10 text-zinc-400">
            <.icon name="hero-chat-bubble-left-right" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Asked to "/runbook" in Slack</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Twenty-three slash commands, three owners, two of whom left in 2024.
            Write-only output, lost in channel scrollback, and the audit trail is whatever
            you remember from the postmortem at 3 a.m.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%!-- Watch it work — the live demo, placed right after the pain so it
       reads as the payoff: here's the problem, now watch emisar handle it. --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Watch it work</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          A real incident, start to finish.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400">
          A CSI driver reformatted a live LUN and wiped 33 hours of metrics. Watch the agent
          investigate through declared actions, stop the writes behind one approval, and hand
          back the durable fix as a Terraform PR — over MCP, no SSH, every step on the record.
        </p>
      </div>

      <.emisar_demo />

      <%!-- The four guarantees the demo just exercised, kept as scannable
           value props (and crawlable copy). --%>
      <dl class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-4">
        <%= for {icon, term, desc} <- [
          {"hero-cpu-chip", "Any MCP client",
           "OAuth for cloud clients, stdio bridge for local tools — access scoped to selected runners or groups."},
          {"hero-shield-exclamation", "Pack trust",
           "New, custom, or changed hashes stop dispatch until an admin trusts the contents."},
          {"hero-hand-raised", "Approvals & grants",
           "Allow a single call, or mint a revocable grant bounded by duration, arguments, runner, and use count."},
          {"hero-document-check", "Searchable audit",
           "Inspect actor and subject context in the portal, or stream NDJSON to your SIEM."}
        ] do %>
          <div>
            <dt class="flex items-center gap-2 text-sm font-semibold text-zinc-100">
              <.icon name={icon} class="h-4 w-4 flex-none text-indigo-400" />{term}
            </dt>
            <dd class="mt-1.5 text-sm leading-relaxed text-zinc-400">{desc}</dd>
          </div>
        <% end %>
      </dl>

      <p class="mt-10 text-center text-sm">
        <.link
          navigate={~p"/use-cases/csi-data-loss"}
          class="inline-flex items-center gap-1 font-medium text-indigo-400 hover:text-indigo-300"
        >
          Read the full post-mortem — the multipath race, the dmesg window, and the Terraform fix
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </p>
    </div>
  </section>

  <%!-- How it works --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">How emisar works</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          From declared action to searchable audit and a hash-chained runner journal.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          No long-lived shells or hidden tools. Every request is checked against the current
          catalog, pack hash, runner scope, and policy before execution.
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-6xl">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-5">
          <%= for {step, title, desc, icon} <- [
            {"01", "DevOps installs or builds a pack", "Actions are declared as YAML, validated, content-addressed, and versioned.", "hero-document-text"},
            {"02", "Runner advertises + verifies", "The outbound-only runner reports its catalog and pack hashes. Changed or custom contents block dispatch until trusted.", "hero-signal"},
            {"03", "LLM calls MCP tool", "Remote clients connect with OAuth; local clients use the stdio bridge. Every call carries a user and runner scope.", "hero-cpu-chip"},
            {"04", "Policy evaluates", "Allow, deny, or page an approver. Decision is recorded before any side effect.", "hero-shield-check"},
            {"05", "Audit + stream", "Redacted output, exit state, policy, and approval context stream to the journal and the portal, can be exported to a SIEM.", "hero-document-check"}
          ] do %>
            <div class="group relative rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 transition hover:-translate-y-0.5 hover:border-indigo-500/40">
              <div class="flex items-center justify-between">
                <span class="font-mono text-xs font-semibold text-indigo-400">{step}</span>
                <.icon
                  name={icon}
                  class="h-5 w-5 text-zinc-500 transition group-hover:text-indigo-400"
                />
              </div>
              <h3 class="mt-6 text-base font-semibold text-white">{title}</h3>
              <p class="mt-2 text-sm text-zinc-400 leading-relaxed">{desc}</p>
            </div>
          <% end %>
        </div>
        <div class="mt-6 hidden items-center justify-between px-8 text-zinc-700 md:flex">
          <span class="font-mono text-xs">pack.yaml</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">register</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">tools/call</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">policy.eval</span>
          <.icon name="hero-arrow-long-right" class="h-4 w-4" />
          <span class="font-mono text-xs">journal.append</span>
        </div>
      </div>
    </div>
  </section>

  <%!-- Three-pillar deep-dive --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Three pillars</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          A catalog, a gate, and a ledger.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Borrow what's safe about deploys: reviewed artifacts, explicit gates, and durable
          history. Apply it to every operational command an LLM is allowed to request.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-7xl grid-cols-1 gap-8 lg:grid-cols-3">
        <%!-- Pillar 1: Catalog --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-cube-transparent" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Versioned action catalog</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Packs live in git. Each pack is content-addressed. Anything outside the manifest is
            refused, and changed contents block dispatch until an admin trusts the new hash.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              packs/linux-core/actions/systemctl_status.yaml
            </div>
            <pre class="p-3 font-mono text-[11px] leading-5 text-zinc-300"><span class="text-indigo-300">schema_version</span>: <span class="text-amber-300">1</span>
<span class="text-indigo-300">id</span>: linux.systemctl_status
<span class="text-indigo-300">title</span>: <span class="text-emerald-300">"Systemd unit status"</span>
<span class="text-indigo-300">kind</span>: exec
<span class="text-indigo-300">risk</span>: <span class="text-amber-300">low</span>
<span class="text-indigo-300">args</span>:
  - <span class="text-indigo-300">name</span>: unit
    <span class="text-indigo-300">type</span>: string
    <span class="text-indigo-300">required</span>: <span class="text-amber-300">true</span>
    <span class="text-indigo-300">validation</span>:
      <span class="text-indigo-300">pattern</span>: <span class="text-emerald-300">"^[a-zA-Z0-9@._-]&#123;1,128&#125;$"</span>  <span class="text-zinc-500"># any systemd unit name</span>
<span class="text-indigo-300">execution</span>:
  <span class="text-indigo-300">command</span>:
    <span class="text-indigo-300">binary</span>: /usr/bin/systemctl
    <span class="text-indigo-300">argv</span>: [<span class="text-emerald-300">"status"</span>, <span class="text-emerald-300">"&#123;&#123; args.unit &#125;&#125;"</span>, <span class="text-emerald-300">"--no-pager"</span>]</pre>
          </div>
        </div>

        <%!-- Pillar 2: Policy --%>
        <div class="rounded-2xl border border-indigo-500/30 bg-zinc-950/60 p-8 ring-1 ring-indigo-500/10">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-shield-check" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Policy &amp; approval</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Set allow, approval, or deny by risk tier, then add stricter action overrides.
            Risky calls wait for a human; approved shapes can receive bounded standing grants.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              Risk-tier defaults
            </div>
            <div class="divide-y divide-zinc-900 p-3 font-mono text-[11px] text-zinc-300">
              <div class="flex items-center justify-between py-2">
                <span>low</span><span class="text-emerald-300">allow</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span>medium</span><span class="text-emerald-300">allow</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span>high</span><span class="text-amber-300">require approval</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span>critical</span><span class="text-rose-300">deny</span>
              </div>
              <div class="pt-3 text-zinc-500">Override: production.* → require approval</div>
            </div>
          </div>
        </div>

        <%!-- Pillar 3: Audit --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
            <.icon name="hero-document-check" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Audit + runner journal</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Every input, output, exit code, and redaction. A SHA-256-chained JSONL journal on the
            host — any edited line or break in the chain is caught by <code class="text-zinc-300">emisar audit verify</code>— mirrored to the
            searchable cloud audit, the system of record, and streamable to your SIEM as NDJSON.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              emisar.dev / audit
            </div>
            <table class="w-full font-mono text-[11px] text-zinc-300">
              <thead class="bg-zinc-950/80 text-zinc-500">
                <tr>
                  <th class="px-3 py-2 text-left font-normal">When</th>
                  <th class="px-3 py-2 text-left font-normal">Event</th>
                  <th class="px-3 py-2 text-left font-normal">Actor</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-900">
                <tr :for={
                  {time, title, type, chip, title_class, actor_kind, actor_label} <- [
                    {"14:02", "Run succeeded", "action_run.success", "docker.ps",
                     "text-emerald-300", "api_key", "claude-prod"},
                    {"14:01", "Awaiting approval", "action_run.pending_approval",
                     "cassandra.nodetool_repair", "text-amber-300", "api_key", "claude-prod"},
                    {"13:58", "Policy evaluated", "policy.evaluated", "require_approval",
                     "text-zinc-300", "system", nil},
                    {"13:52", "Denied by policy", "action_run.denied", "linux.reboot_host",
                     "text-rose-300", "api_key", "claude-prod"}
                  ]
                }>
                  <td class="px-3 py-2 align-top text-zinc-500">{time}</td>
                  <td class="px-3 py-2">
                    <div class={title_class}>{title}</div>
                    <div class="text-[10px] text-zinc-500">{type}</div>
                    <span class="mt-1 inline-block rounded bg-zinc-800/60 px-1.5 py-0.5 text-[10px] text-zinc-400">
                      {chip}
                    </span>
                  </td>
                  <td class="px-3 py-2 align-top leading-5">
                    <span :if={actor_label} class="text-zinc-500">{actor_kind}:</span>
                    <span :if={actor_label} class="text-indigo-300">{actor_label}</span>
                    <span :if={!actor_label} class="text-zinc-400">{actor_kind}</span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- Action catalog example --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">The action contract</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          One YAML file. One source of truth.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          This abbreviated action YAML is the operator-authored contract behind <code class="font-mono text-indigo-300">cassandra.nodetool_repair</code>.
          The LLM receives a tool schema derived from it; the runner refuses anything
          outside it.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl rounded-xl border border-zinc-900 bg-black/60 shadow-2xl shadow-indigo-950/20">
        <div class="flex min-w-0 items-center gap-2 border-b border-zinc-900 px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
          <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
          <span class="ml-3 min-w-0 truncate font-mono text-xs text-zinc-500">
            packs/cassandra/actions/nodetool_repair.yaml
          </span>
        </div>
        <pre class="overflow-x-auto p-6 font-mono text-xs leading-6 text-zinc-300"><span class="text-zinc-500">## Abbreviated: repair a Cassandra keyspace.</span>
<span class="text-indigo-300">schema_version</span>: <span class="text-amber-300">1</span>
<span class="text-indigo-300">id</span>: cassandra.nodetool_repair
<span class="text-indigo-300">title</span>: <span class="text-emerald-300">"Cassandra repair"</span>
<span class="text-indigo-300">kind</span>: exec
<span class="text-indigo-300">risk</span>: <span class="text-amber-300">high</span>            <span class="text-zinc-500"># forces policy to require_approval by default</span>

<span class="text-indigo-300">args</span>:
  - <span class="text-indigo-300">name</span>: keyspace
    <span class="text-indigo-300">type</span>: string
    <span class="text-indigo-300">required</span>: <span class="text-amber-300">true</span>
    <span class="text-indigo-300">validation</span>:
      <span class="text-indigo-300">pattern</span>: <span class="text-emerald-300">"^[a-zA-Z][a-zA-Z0-9_]&#123;0,47&#125;$"</span>
  - <span class="text-indigo-300">name</span>: parallelism
    <span class="text-indigo-300">type</span>: string
    <span class="text-indigo-300">default</span>: <span class="text-emerald-300">sequential</span>
    <span class="text-indigo-300">validation</span>:
      <span class="text-indigo-300">enum</span>: [<span class="text-emerald-300">sequential</span>, <span class="text-emerald-300">parallel</span>, <span class="text-emerald-300">dc_parallel</span>]

<span class="text-indigo-300">execution</span>:
  <span class="text-indigo-300">command</span>:
    <span class="text-indigo-300">binary</span>: /usr/bin/nodetool
    <span class="text-indigo-300">argv</span>:
      - <span class="text-emerald-300">"repair"</span>
      - <span class="text-emerald-300">"&#123;&#123; args.keyspace &#125;&#125;"</span>
  <span class="text-indigo-300">timeout</span>: 6h
  <span class="text-indigo-300">cancel_grace</span>: 5m

<span class="text-indigo-300">output</span>:
  <span class="text-indigo-300">parser</span>: text
  <span class="text-indigo-300">max_stdout_bytes</span>: <span class="text-amber-300">4194304</span>
  <span class="text-indigo-300">max_stderr_bytes</span>: <span class="text-amber-300">262144</span></pre>
      </div>
      <p class="mx-auto mt-6 max-w-2xl text-center text-sm text-zinc-400">
        This is the contract. The LLM sees only what you declare; your SRE sees every invocation.
      </p>
      <div class="mt-8 flex justify-center">
        <.link
          navigate={~p"/packs"}
          class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-400 hover:text-indigo-300"
        >
          Browse the pack registry — Postgres, Cassandra, Docker, Kubernetes, the AWS suite, and dozens more
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- Comparison table --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Why not just&hellip;</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The alternatives, honestly.
        </p>
      </div>

      <div class="mx-auto mt-16 overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-zinc-900 text-xs uppercase tracking-wider text-zinc-500">
                <th class="px-6 py-4 font-medium"></th>
                <th class="px-6 py-4 font-semibold text-indigo-300">emisar</th>
                <th class="px-6 py-4 font-medium">Raw SSH key</th>
                <th class="px-6 py-4 font-medium">Custom MCP server</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-900 text-zinc-300">
              <%= for {row, em, ssh, mcp} <- [
                {"Typed action contract", "yes", "no", "maybe"},
                {"Pack drift blocks dispatch", "yes", "no", "no"},
                {"Risk-tier policy + overrides", "yes", "no", "maybe"},
                {"Approvals + standing grants", "yes", "no", "no"},
                {"Per-user runner scopes", "yes", "no", "maybe"},
                {"Streaming stdout/stderr", "yes", "yes", "maybe"},
                {"Audit + SIEM export", "yes", "no", "maybe"},
                {"Setup time", "5 min", "instant + nightmares", "1-2 weeks"}
              ] do %>
                <tr class="hover:bg-zinc-900/30">
                  <td class="px-6 py-4 font-medium text-zinc-100">{row}</td>
                  <td class="px-6 py-4">
                    <%= cond do %>
                      <% em == "yes" -> %>
                        <span class="inline-flex items-center gap-1.5 text-emerald-300">
                          <.icon name="hero-check-circle" class="h-4 w-4" />{if row ==
                                                                                  "Setup time",
                                                                                do: em,
                                                                                else: "Yes"}
                        </span>
                      <% true -> %>
                        {em}
                    <% end %>
                  </td>
                  <%= for v <- [ssh, mcp] do %>
                    <td class="px-6 py-4">
                      <%= cond do %>
                        <% v == "yes" -> %>
                          <span class="inline-flex items-center gap-1.5 text-emerald-400/80">
                            <.icon name="hero-check" class="h-4 w-4" />Yes
                          </span>
                        <% v == "no" -> %>
                          <span class="inline-flex items-center gap-1.5 text-zinc-500">
                            <.icon name="hero-x-mark" class="h-4 w-4" />No
                          </span>
                        <% v == "maybe" -> %>
                          <span class="inline-flex items-center gap-1.5 text-amber-400/70">
                            <.icon name="hero-minus" class="h-4 w-4" />Partial
                          </span>
                        <% true -> %>
                          <span class="text-zinc-400">{v}</span>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-3 text-center">
        <.link
          navigate={~p"/compare/raw-ssh-for-ai"}
          class="inline-flex items-center gap-1 text-sm font-medium text-indigo-400 hover:text-indigo-300"
        >
          Read the full SSH-for-AI comparison
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
        <.link
          navigate={~p"/compare/custom-mcp-server"}
          class="inline-flex items-center gap-1 text-sm font-medium text-indigo-400 hover:text-indigo-300"
        >
          Compare with a custom MCP server <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- Zero Trust validation — third-party framework. Shaded so it pops
    between the comparison table above and the example workflows below. --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Zero Trust for AI Agents</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The framework a frontier lab published — enforced by emisar.
        </p>
        <p class="mt-6 text-lg leading-8 text-zinc-400">
          Anthropic's
          <a
            href="https://cdn.prod.website-files.com/6889473510b50328dbb70ae6/6a1611a04085d7cd3dadc924_Claude-eBook-Zero-Trust-for-AI-Agents-05182026.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="text-indigo-300 underline decoration-zinc-700 underline-offset-4 hover:text-indigo-200"
          >
            Zero Trust for AI Agents
          </a>
          guide says an agent with access to real systems needs least agency, deny-by-default
          tools, human approval for high-risk actions, and an immutable audit trail. That's the
          exact boundary emisar enforces — several of which the framework files under its Enterprise
          and Advanced tiers, shipped on emisar's Free plan.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <%= for {principle, detail} <- [
          {"Least agency", "Typed action contract — the agent only sees declared tools"},
          {"Human in the loop", "High-risk actions stop for a one-click approval"},
          {"Tamper-evident audit", "Searchable portal audit, a hash-chained host journal, and SIEM export"},
          {"Assume breach", "A jailbroken agent still can't exceed the catalog"}
        ] do %>
          <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 text-left">
            <h3 class="text-sm font-semibold text-indigo-300">{principle}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{detail}</p>
          </div>
        <% end %>
      </div>

      <div class="mt-10 text-center">
        <.link
          navigate={~p"/zero-trust"}
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-400 hover:text-indigo-300"
        >
          See emisar mapped to the framework, control by control
          <.icon name="hero-arrow-right" class="h-4 w-4" />
        </.link>
        <p class="mx-auto mt-4 max-w-xl text-xs leading-relaxed text-zinc-500">
          Not affiliated with or endorsed by Anthropic. We cite the framework because emisar is
          built to the control set it describes.
        </p>
      </div>
    </div>
  </section>

  <%!-- Use cases --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Example workflows</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Operational actions teams can expose without exposing a shell.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <%= for {tag, title, scenario, icon, href} <- [
          {"cassandra", "Cassandra ops", "Agent triages a slow read latency alert by running nodetool.status, then proposes nodetool.repair on the lagging keyspace — pending one approver click.", "hero-circle-stack", ~p"/use-cases/cassandra-ops"},
          {"postgres", "Postgres ops", "Replication lag spikes overnight. The model checks lag and slow queries, then requests approval before terminating the blocking backend.", "hero-server-stack", ~p"/use-cases/postgres-ops"},
          {"incident", "Incident response", "A CSI driver reformats a live volume and wipes 33 hours of metrics. The agent investigates through declared actions, stops the bleed behind one approval, and writes the durable fix to Terraform.", "hero-bell-alert", ~p"/use-cases/csi-data-loss"}
        ] do %>
          <div class="group flex flex-col rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-indigo-500/40">
            <div class="flex items-center justify-between">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-500/10 text-indigo-400">
                <.icon name={icon} class="h-5 w-5" />
              </div>
              <span class="font-mono text-[10px] uppercase tracking-widest text-zinc-500">
                {tag}
              </span>
            </div>
            <h3 class="mt-6 text-lg font-semibold text-white">{title}</h3>
            <p class="mt-3 text-sm text-zinc-400 leading-relaxed">{scenario}</p>
            <.link
              :if={href}
              navigate={href}
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-indigo-400 hover:text-indigo-300"
            >
              Read the playbook <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
            </.link>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Pricing teaser --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-indigo-400">Pricing</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Pay per runner. Not per seat.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Free for 3 runners and 1 user. Team is $20/runner/month with unlimited users.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Free</h3>
          <p class="mt-2 text-sm text-zinc-400">For homelab and tinkering.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$0</span>
            <span class="text-sm text-zinc-500">/ forever</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" /> 3 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" /> 1 user
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              7-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Community support
            </li>
          </ul>
        </div>
        <div class="relative rounded-2xl border-2 border-indigo-500/60 bg-zinc-950/80 p-8 shadow-2xl shadow-indigo-950/40">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-indigo-500 px-3 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-zinc-950">
            Most popular
          </span>
          <h3 class="text-lg font-semibold text-white">Team</h3>
          <p class="mt-2 text-sm text-zinc-400">For teams running real production.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$20</span>
            <span class="text-sm text-zinc-500">/ runner / month</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Up to 100 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Unlimited users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              90-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Monthly invoices, email support
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Enterprise</h3>
          <p class="mt-2 text-sm text-zinc-400">For regulated environments &amp; fleets.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">Custom</span>
          </div>
          <ul class="mt-6 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Unlimited runners &amp; users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              365-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Security and procurement review
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-indigo-400" />
              Design-partner deployment planning
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 flex justify-center">
        <.marketing_button variant={:secondary} href={~p"/pricing"} icon="hero-arrow-right">
          Compare all plans
        </.marketing_button>
      </div>
    </div>
  </section>

  <%!-- FAQ --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-indigo-400">FAQ</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl">
          The skeptical questions, answered.
        </p>
      </div>

      <div class="mt-16 divide-y divide-zinc-900 rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between px-8 py-6 text-base font-semibold text-white">
              {q}
              <.icon name="hero-plus" class="h-5 w-5 text-zinc-500 transition group-open:hidden" />
              <.icon name="hero-minus" class="hidden h-5 w-5 text-indigo-400 group-open:block" />
            </summary>
            <p class="px-8 pb-6 text-sm text-zinc-400 leading-relaxed">{a}</p>
          </details>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Final CTA --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="overflow-hidden rounded-lg border border-indigo-500/30 bg-zinc-950 p-12 sm:p-16">
        <div class="text-center">
          <.marketing_heading tag="h2" scale={:section}>
            Sleep tonight. Sign up free.
          </.marketing_heading>
          <p class="mx-auto mt-6 max-w-xl text-lg text-zinc-400 leading-relaxed">
            Three runners. Seven-day audit. No credit card. Read the quickstart and
            ship your first policy-gated LLM action.
          </p>
          <form
            action={~p"/sign_up"}
            method="get"
            class="mx-auto mt-10 flex max-w-md flex-col items-center gap-3 sm:flex-row"
          >
            <label for="cta-email" class="sr-only">Work email</label>
            <input
              type="email"
              name="email"
              id="cta-email"
              placeholder="you@company.com"
              class="w-full rounded-lg border-0 bg-zinc-900/80 px-4 py-2.5 text-sm text-white ring-1 ring-zinc-800 placeholder:text-zinc-500 focus:ring-2 focus:ring-indigo-500"
            />
            <.marketing_button type="submit" icon="hero-arrow-right" class="w-full sm:w-auto">
              Start free
            </.marketing_button>
          </form>
          <p class="mt-4 text-xs text-zinc-400">
            No credit card. Cancel anytime. Your audit log is yours to export.
          </p>
        </div>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
