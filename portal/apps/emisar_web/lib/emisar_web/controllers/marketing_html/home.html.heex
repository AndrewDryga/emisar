<%!-- ============================================================
  Home — emisar marketing landing
  Give your LLM safe access to production. Without the panic.
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100 antialiased">
  <.marketing_nav current_user={@current_user} current={:home} sticky />

  <%!-- Hero --%>
  <section class="relative overflow-hidden border-b border-zinc-900 bg-[#07080a]">
    <div class="contract-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <div class="relative mx-auto w-full max-w-7xl px-6 py-12 sm:py-20 lg:px-8">
      <div class="max-w-5xl">
        <.marketing_heading
          tag="h1"
          scale={:display}
          class="rise-1 max-w-4xl !text-4xl/[1.1] sm:!text-6xl/[1.1] md:!text-7xl/[1.1]"
        >
          Your AI agent needs production access&nbsp;— not your SSH key.
        </.marketing_heading>
        <p class="rise-2 mt-6 max-w-2xl text-lg leading-relaxed text-zinc-300">
          emisar is one governed MCP server that connects Claude, Cursor, ChatGPT — any AI
          agent — to your infrastructure. One server covers production access, debugging, alerting,
          runbooks, and internal ops — so a new capability is another pack, not another MCP server
          to roll out to every client. Your agent reads real production state to debug what it
          shipped and help work incidents. Safe reads run on their own. A risky change waits for a
          human to approve it. No SSH key, no always-on access, every call on the record.
        </p>
        <div class="rise-3 mt-8 flex flex-wrap items-center gap-4">
          <.marketing_button href={~p"/sign_up"} icon="hero-arrow-right">
            Start free
          </.marketing_button>
          <.marketing_button variant={:secondary} href={~p"/docs/quickstart"}>
            Run the quickstart
          </.marketing_button>
        </div>
        <p class="rise-4 mt-6 text-xs text-zinc-400">
          Free for 3 runners &middot; No credit card &middot;
          <a
            href="https://github.com/andrewdryga/emisar/blob/main/runner/LICENSE"
            target="_blank"
            rel="noopener noreferrer"
            class="underline-offset-2 hover:text-zinc-200 hover:underline"
          >
            Apache-2.0 open-source runner
          </a>
        </p>
      </div>

      <%!-- The agent at work in production: investigate freely, act on approval.
           Every call passes the gate — reads clear on policy, the one risky
           change waits for a human. Simpler than a contract dump on purpose;
           the full incident is the demo further down. --%>
      <div class="rise-5 surface-glass mt-10 overflow-hidden rounded-xl border border-zinc-800">
        <div class="flex items-center justify-between gap-3 border-b border-zinc-800 bg-zinc-950 px-4 py-2.5 font-mono text-[11px] text-zinc-500">
          <span class="flex items-center gap-2">
            <.icon name="hero-sparkles" class="h-3.5 w-3.5 text-brand-400" /> claude · emisar MCP
          </span>
          <span class="hidden sm:inline">scoped to prod-nomad-cluster</span>
        </div>

        <div class="p-3 sm:p-5">
          <.scan_line animate loop state={:pass} class="mb-4" />
          <div class="divide-y divide-zinc-900/80 font-mono text-[11.5px] leading-6 tabular-nums sm:text-[12.5px]">
            <%= for {call, kind} <- [
                {"nomad.alloc_logs checkout", :read},
                {"prom.query rate(http_5xx)", :read},
                {"nomad.job_history checkout", :read},
                {"nomad.job_revert checkout", :write}
              ] do %>
              <div class="grid grid-cols-[1fr_auto] items-center gap-2 py-2.5 first:pt-0 last:pb-0 sm:gap-3">
                <span class="flex min-w-0 items-center gap-2 text-zinc-300">
                  <span class="flex-none text-brand-400">⏺</span>
                  <span class="min-w-0 truncate">{call}</span>
                </span>
                <%= if kind == :write do %>
                  <span class="flex flex-none items-center gap-1.5">
                    <.state_chip state={:pending} label="approval" />
                    <%!-- The approval beat would clip at 390px; reveal it sm+ and let
                           mobile show just the pending "waiting on a human" signal. The
                           hand, not an arrow, makes the human the thing that resolves it. --%>
                    <span class="hidden items-center gap-1.5 sm:flex">
                      <.icon name="hero-hand-raised" class="h-3 w-3 text-brand-400" />
                      <.state_chip
                        state={:pass}
                        label="approved"
                        class="w-[6.25rem] justify-center"
                      />
                    </span>
                  </span>
                <% else %>
                  <.state_chip
                    state={:pass}
                    label="allowed"
                    class="w-[5.5rem] flex-none justify-center"
                  />
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <%!-- The durable fix — emisar grounds the investigation; the agent then
             ships the root-cause fix as reviewable code, not a throwaway restart. --%>
        <div class="flex items-start gap-2 border-t border-zinc-900/80 px-4 py-3 font-mono text-[11px] leading-5 text-zinc-400">
          <.icon
            name="hero-code-bracket-square"
            class="mt-0.5 h-3.5 w-3.5 flex-none text-zinc-500"
          />
          <span>
            then <span class="text-zinc-300">claude</span>
            opens a PR with the <span class="text-brand-300">durable fix</span>
            — the corrected
            Nomad job spec, in its own coding tools. emisar gave it the facts; the agent writes the fix.
          </span>
        </div>

        <div class="border-t border-zinc-800 bg-zinc-950/80 px-4 py-3 text-center font-mono text-[11px] text-zinc-500">
          Safe reads run on their own · risky changes wait for one human · every call audited
        </div>
      </div>
    </div>
  </section>

  <%!-- Proof strip — no logo wall yet (no on-record customers to show), so the
       trust bar is concrete instead: the catalog's real scale, the framework emisar is built to, the
       audit guarantee, and the open license. Sits on the hero's own dark ground
       (a strip, not an eyebrow→H2 section) so it reads as the hero's footing and
       adds substance above the fold without adding to the page's section rhythm. --%>
  <section class="border-b border-zinc-900 bg-[#07080a]" aria-label="emisar at a glance">
    <div class="mx-auto grid max-w-7xl grid-cols-2 px-6 sm:grid-cols-4 sm:divide-x sm:divide-zinc-900 lg:px-8">
      <div class="border-b border-zinc-900 px-4 py-6 text-center sm:border-b-0 sm:py-7">
        <div class="font-mono text-2xl font-bold tabular-nums text-zinc-50">{@action_count}</div>
        <div class="mt-1 text-xs text-zinc-500">audited actions &middot; {@pack_count} packs</div>
      </div>
      <.link
        navigate={~p"/zero-trust"}
        class="group border-b border-zinc-900 px-4 py-6 text-center sm:border-b-0 sm:py-7"
      >
        <div class="text-base font-semibold text-zinc-100 transition group-hover:text-brand-300">
          Zero-Trust for AI
        </div>
        <div class="mt-1 text-xs text-zinc-500">built to Anthropic's control set</div>
      </.link>
      <div class="px-4 py-6 text-center sm:py-7">
        <div class="text-base font-semibold text-zinc-100">Hash-chained journal</div>
        <div class="mt-1 text-xs text-zinc-500">every action, tamper-evident on the host</div>
      </div>
      <a
        href="https://github.com/andrewdryga/emisar/blob/main/LICENSE.md"
        target="_blank"
        rel="noopener noreferrer"
        class="group px-4 py-6 text-center sm:py-7"
      >
        <div class="text-base font-semibold text-zinc-100 transition group-hover:text-brand-300">
          Open code
        </div>
        <div class="mt-1 text-xs text-zinc-500">
          Apache-2.0 runner &middot; read the whole control plane
        </div>
      </a>
    </div>
  </section>

  <%!-- "Your AI is brilliant. And blind." — the canonical "what your agent
       gains with production access" section: the brilliant-and-blind framing,
       the read-everything breadth, and the act-only-behind-approval line.
       Unshaded so the page alternates cleanly after the dark hero + proof
       strip. --%>
  <section class="py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <%!-- Asymmetric layout (left pitch / right capability list), deliberately
           NOT the centered card-grid the page uses elsewhere — it gives the top
           of the page movement and its own distinct shape. --%>
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h2 class="text-base font-semibold text-brand-400">With eyes on production</h2>
          <p class="mt-2 text-4xl font-bold tracking-tight text-white text-balance sm:text-5xl">
            Your AI is brilliant. And blind.
          </p>
          <p class="mt-6 text-lg leading-relaxed text-zinc-400 text-pretty">
            Claude, Cursor, and ChatGPT reason about your stack all day — but they can't see it
            running. emisar gives your agent eyes on production. It reads live logs, metrics, hosts,
            datastores, and the network, so its plan matches what's actually running. It catches its
            own mistakes. It works incidents beside you. And it stops for you only when a change is
            actually risky.
          </p>
          <p class="mt-8 text-sm">
            <.link
              navigate={~p"/packs"}
              class="inline-flex items-center gap-1 font-medium text-brand-400 hover:text-brand-300"
            >
              Browse the full catalog it can reach
              <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
            </.link>
          </p>
        </div>

        <div class="space-y-3">
          <%= for {icon, title, desc} <- [
            {"hero-magnifying-glass", "Starts from real state",
             "Before it writes a line, the agent reads live logs, metrics, configs, and process state. Its plan is based on what's actually running — not a stale guess from training data."},
            {"hero-bug-ant", "Debugs what it shipped",
             "Deployed something that misbehaves? The agent inspects the running result, finds its own mistake, and proposes the fix. You don't have to gather the context for it."},
            {"hero-bell-alert", "Works the incident",
             "When the page fires, it triages across the fleet, lines up logs against metrics, and narrows the cause. Then it hands you a fix it can run the moment you approve."},
            {"hero-bolt", "The change waits for you",
             "When the fix actually changes something, that's the one moment you step in — one approval, scoped and logged. Everything safe runs without you."}
          ] do %>
            <div class="flex gap-4 rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6">
              <div class="flex h-10 w-10 flex-none items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
                <.icon name={icon} class="h-5 w-5" />
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">{title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-zinc-400">{desc}</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <%!-- Pain section. Shaded — it takes the slot the (now-removed) dark
       Assume-Breach panel used to separate, keeping the section rhythm
       alternating. --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">How it's done today</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Today, your AI agent is either:
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Three common setups for letting an agent act — and each fails the same way: no gate
          before the action, no trustworthy record after.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:max-w-none lg:grid-cols-3">
        <div class="rounded-2xl border border-red-900/40 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-red-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-red-500/10 text-red-400">
            <.icon name="hero-command-line" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Given a raw SSH key</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Full shell on prod. The model is "creative." A malformed request can become
            <code class="rounded bg-zinc-900 px-1 py-0.5 text-xs text-red-300">
              rm&nbsp;-rf&nbsp;/var/lib/postgresql
            </code>
            with no policy gate and no durable record of why it happened.
          </p>
        </div>
        <div class="rounded-2xl border border-amber-900/40 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-amber-900/60">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-amber-400">
            <.icon name="hero-puzzle-piece" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Wired to a custom tool server</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Two engineers built a custom MCP server in a weekend. It hardcodes one cluster,
            swallows stderr, has no approval flow, and lives in a repo nobody dares touch.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-zinc-700">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-500/10 text-zinc-400">
            <.icon name="hero-chat-bubble-left-right" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Asked to "/runbook" in Slack</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Twenty-three slash commands, three owners, two of whom left in 2024.
            Write-only output, lost in channel scrollback, and the audit trail is whatever
            you remember from the postmortem.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%!-- Three-pillar deep-dive — the mechanism, placed right after the pain it
       answers: the alternatives leave "no gate before, no record after"; emisar's
       answer is a catalog, a gate, and a ledger. Unshaded, so it alternates
       between the shaded pain above and the shaded demo below. --%>
  <section class="py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">Three pillars</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          A catalog, a gate, and a ledger.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Every request is handled the same way. Each action declares what it can do and carries a
          risk tier — low, medium, high, or critical. The policy you set decides which tiers need a
          human to approve. The runner re-checks the request before it runs. Then every call is
          recorded twice — to the searchable audit in the portal, and to a hash-chained journal on
          the runner host.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-7xl grid-cols-1 gap-8 lg:grid-cols-3">
        <%!-- Pillar 1: Catalog --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name="hero-cube-transparent" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Versioned action catalog</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Packs live in git, and each one is fingerprinted by its contents. The AI sees only the
            actions you declared — it can't ask for anything else. Change a pack and emisar stops
            running it until an admin trusts the new version. A new surface — another datastore,
            your alerting stack, an internal API — is one more trusted pack on the same gate, not
            another MCP server to roll out to every client.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              linux-core/actions/systemctl_status.yaml
            </div>
            <pre class="overflow-x-auto p-3 font-mono text-[11px] leading-5 text-zinc-300"><span class="text-sky-300">schema_version</span>: <span class="text-amber-300">1</span>
<span class="text-sky-300">id</span>: linux.systemctl_status
<span class="text-sky-300">title</span>: <span class="text-brand-300">"Systemd unit status"</span>
<span class="text-sky-300">kind</span>: exec
<span class="text-sky-300">risk</span>: <span class="text-amber-300">low</span>
<span class="text-sky-300">args</span>:
  - <span class="text-sky-300">name</span>: unit
    <span class="text-sky-300">type</span>: string
    <span class="text-sky-300">required</span>: <span class="text-amber-300">true</span>
    <span class="text-sky-300">validation</span>:
      <span class="text-sky-300">pattern</span>: <span class="text-brand-300">"^[a-zA-Z0-9@._-]&#123;1,128&#125;$"</span>
<span class="text-sky-300">execution</span>:
  <span class="text-sky-300">command</span>:
    <span class="text-sky-300">binary</span>: /usr/bin/systemctl
    <span class="text-sky-300">argv</span>: [<span class="text-brand-300">"status"</span>, <span class="text-brand-300">"&#123;&#123; args.unit &#125;&#125;"</span>]</pre>
          </div>
        </div>

        <%!-- Pillar 2: Policy --%>
        <div class="rounded-2xl border border-brand-500/30 bg-zinc-950/60 p-8 ring-1 ring-brand-500/10">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name="hero-shield-check" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Policy &amp; approval</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Set allow, ask-for-approval, or deny for each risk tier, then override specific actions.
            Risky calls wait for a human. Or hand out a limited, revocable pass so routine ones
            don't ask every time.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              Risk-tier defaults
            </div>
            <div class="divide-y divide-zinc-900 p-3 font-mono text-[11px] text-zinc-300">
              <div class="flex items-center justify-between py-2">
                <span>low</span><span class="text-brand-300">allow</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span>medium</span><span class="text-brand-300">allow</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span>high</span><span class="text-amber-300">require approval</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span>critical</span><span class="text-rose-300">deny</span>
              </div>
              <div class="flex items-center justify-between pt-3 text-[10px] uppercase tracking-wider text-zinc-600">
                <span>Overrides</span>
                <span class="normal-case tracking-normal">first match wins</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span class="truncate text-zinc-400">*.delete_*</span>
                <span class="ml-3 flex-none text-rose-300">deny</span>
              </div>
              <div class="flex items-center justify-between py-2">
                <span class="truncate text-zinc-400">nomad.job_*</span>
                <span class="ml-3 flex-none text-amber-300">require approval</span>
              </div>
              <div class="pt-3 text-[10px] leading-4 text-zinc-500">
                Or scope a stricter ruleset to a single runner or a group.
              </div>
            </div>
          </div>
        </div>

        <%!-- Pillar 3: Audit --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
            <.icon name="hero-document-check" class="h-5 w-5" />
          </div>
          <h3 class="mt-6 text-xl font-semibold text-white">Audit + runner journal</h3>
          <p class="mt-3 text-sm text-zinc-400 leading-relaxed">
            Every input, output, exit code, and redaction is recorded. On the host it's a
            hash-chained log — change one line and
            <code class="text-zinc-300">emisar audit verify</code>
            catches it. It's mirrored to the searchable audit in the portal, and it can stream to
            your SIEM.
          </p>
          <div class="mt-6 overflow-hidden rounded-lg border border-zinc-900 bg-black/60">
            <div class="border-b border-zinc-900 px-3 py-2 font-mono text-[11px] text-zinc-500">
              emisar.dev / audit
            </div>
            <div class="divide-y divide-zinc-900 font-mono text-[11px] tabular-nums">
              <div
                :for={
                  {time, title, type, chip, title_class, actor_kind, actor_label} <- [
                    {"14:02", "Run succeeded", "action_run.success", "nomad.alloc_logs",
                     "text-brand-300", "api_key", "claude-prod"},
                    {"14:01", "Awaiting approval", "action_run.pending_approval",
                     "nomad.job_revert", "text-amber-300", "api_key", "claude-prod"},
                    {"13:58", "Approval granted", "approval.approved", "caddy.reload_config",
                     "text-brand-300", "user", "ops@acme.co"},
                    {"13:52", "Denied by policy", "action_run.denied", "linux.reboot_host",
                     "text-rose-300", "api_key", "claude-prod"}
                  ]
                }
                class="flex gap-3 px-3 py-2.5"
              >
                <span class="flex-none text-zinc-500">{time}</span>
                <div class="min-w-0 flex-1">
                  <div class={[title_class, "font-medium"]}>{title}</div>
                  <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-[10px] text-zinc-500">
                    <span>{type}</span>
                    <span class="rounded bg-zinc-800/60 px-1.5 py-0.5 text-zinc-400">{chip}</span>
                  </div>
                  <%!-- Actor on its own line, consistent across rows. System
                       (engine) actor is highlighted like the api_key actors. --%>
                  <div class="mt-1 text-[10px] text-zinc-500">
                    <span :if={actor_label}>
                      {actor_kind}: <span class="text-brand-300">{actor_label}</span>
                    </span>
                    <span :if={!actor_label} class="text-zinc-300">{actor_kind}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 flex justify-center">
        <.link
          navigate={~p"/packs"}
          class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          Browse all {@action_count} actions across {@pack_count} packs — Postgres, Docker, Nomad, Kubernetes, the AWS suite, and more
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- Watch it work — the live demo, right after the mechanism above: the
       reader has seen the catalog, the gate, and the ledger; now all three run
       a real incident end to end. --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">Watch it work</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          A real incident, start to finish.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400 text-pretty">
          A CSI driver reformatted a live LUN and wiped 33 hours of metrics. Watch the agent
          investigate through declared actions, stop the writes behind one approval, and hand
          back the durable fix as a Terraform PR — over MCP, no SSH, every step on the record.
        </p>
      </div>

      <.emisar_demo />

      <%!-- The four guarantees the demo just exercised, kept as scannable
           value props (and crawlable copy). --%>
      <dl class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-4">
        <%= for {icon, term, desc} <- [
          {"hero-cpu-chip", "Any MCP client",
           "OAuth for cloud clients, stdio bridge for local tools — access scoped to selected runners or groups."},
          {"hero-shield-exclamation", "Pack trust",
           "New or changed packs stop running until an admin trusts the contents."},
          {"hero-hand-raised", "Approvals & grants",
           "Approve one call, or hand out a revocable pass — limited by time, arguments, runner, and number of uses."},
          {"hero-document-check", "Searchable audit",
           "See who ran what, and on whose behalf, in the portal — or stream it to your SIEM."}
        ] do %>
          <div>
            <dt class="flex items-center gap-2 text-sm font-semibold text-zinc-100">
              <.icon name={icon} class="h-4 w-4 flex-none text-brand-400" />{term}
            </dt>
            <dd class="mt-1.5 text-sm leading-relaxed text-zinc-400">{desc}</dd>
          </div>
        <% end %>
      </dl>

      <p class="mt-10 text-center text-sm">
        <.link
          navigate={~p"/use-cases/csi-data-loss"}
          class="inline-flex items-center gap-1 font-medium text-brand-400 hover:text-brand-300"
        >
          Read the full post-mortem — the multipath race, the dmesg window, and the Terraform fix
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </p>
    </div>
  </section>

  <%!-- Comparison table --%>
  <section class="py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">Why not just&hellip;</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          The alternatives, honestly.
        </p>
      </div>

      <div class="mx-auto mt-16 overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-zinc-900 text-xs uppercase tracking-wider text-zinc-500">
                <th class="px-6 py-4 font-medium"></th>
                <th class="px-6 py-4 font-semibold text-brand-300">emisar</th>
                <th class="px-6 py-4 font-medium">Raw SSH key</th>
                <th class="px-6 py-4 font-medium">Custom MCP server</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-900 text-zinc-300">
              <%= for {row, em, ssh, mcp} <- [
                {"Typed action contract", "yes", "no", "maybe"},
                {"Pack drift blocks dispatch", "yes", "no", "no"},
                {"Risk-tier policy + overrides", "yes", "no", "maybe"},
                {"Approvals + standing grants", "yes", "no", "no"},
                {"Per-user runner scopes", "yes", "no", "maybe"},
                {"Streaming stdout/stderr", "yes", "yes", "maybe"},
                {"Audit + SIEM export", "yes", "no", "maybe"},
                {"Setup time", "5 min", "instant + nightmares", "1-2 weeks"}
              ] do %>
                <tr class="hover:bg-zinc-900/30">
                  <td class="px-6 py-4 font-medium text-zinc-100">{row}</td>
                  <td class="px-6 py-4">
                    <%= if em == "yes" do %>
                      <.state_chip state={:pass} label="Yes" />
                    <% else %>
                      <span class="font-medium text-brand-300">{em}</span>
                    <% end %>
                  </td>
                  <%= for v <- [ssh, mcp] do %>
                    <td class="px-6 py-4">
                      <%= cond do %>
                        <% v == "yes" -> %>
                          <.state_chip state={:pass} label="Yes" />
                        <% v == "maybe" -> %>
                          <.state_chip state={:pending} label="Partial" />
                        <% v == "no" -> %>
                          <%!-- Absence, not a denial: a competitor lacking a
                               feature stays muted so emisar's column wins by
                               contrast — a table full of rose reads as fear. --%>
                          <span class="inline-flex items-center gap-1.5 text-zinc-500">
                            <.icon name="hero-x-mark" class="h-4 w-4" />No
                          </span>
                        <% true -> %>
                          <span class="text-zinc-400">{v}</span>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-3 text-center">
        <.link
          navigate={~p"/compare/raw-ssh-for-ai"}
          class="inline-flex items-center gap-1 text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          Read the full SSH-for-AI comparison
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
        <.link
          navigate={~p"/compare/custom-mcp-server"}
          class="inline-flex items-center gap-1 text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          Compare with a custom MCP server <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
        <.link
          navigate={~p"/compare/copy-paste-ai-ops"}
          class="inline-flex items-center gap-1 text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          Compare with the copy-paste workflow
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- Case studies — proof the demo wasn't cherry-picked: the storage wipe from
       the demo written up in full, plus a completely different failure on the
       network. These are the two REAL incidents; the weaker "real-shape" datastore
       walkthroughs (Postgres/Cassandra) were cut from the showcase — they live on
       as pack-supporting pages, reachable from their packs and docs. Each card
       links to its post-mortem; the hub link below carries the everyday wins too. --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">Case studies</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Two incidents, in full.
        </p>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400 text-pretty">
          The storage wipe from the demo, written up end to end — and a completely different
          failure on the network. Both real, both logged with the command output to prove it.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-3xl grid-cols-1 gap-6 sm:grid-cols-2">
        <%= for {tag, title, scenario, icon, href} <- [
          {"storage", "A CSI driver wiped 33 hours of metrics",
           "The incident from the demo, in full — including the twist. The obvious one-line fix was a no-op, so the durable fix the agent shipped is a guard that refuses to trust the driver.",
           "hero-circle-stack", ~p"/use-cases/csi-data-loss"},
          {"ingress", "A fleet-wide 502 no backend was causing",
           "Every app behind one edge threw intermittent 502s — yet every backend was green. The agent traced it across five layers to an OOM loop and a wedged node still advertising a dead ingress, then stopped the bleed behind gated approvals.",
           "hero-globe-alt", ~p"/use-cases/ingress-502"}
        ] do %>
          <div class="group flex flex-col rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8 transition hover:-translate-y-0.5 hover:border-brand-500/40">
            <div class="flex items-center justify-between">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
                <.icon name={icon} class="h-5 w-5" />
              </div>
              <span class="font-mono text-[10px] uppercase tracking-widest text-zinc-500">
                {tag}
              </span>
            </div>
            <h3 class="mt-6 text-lg font-semibold text-white">{title}</h3>
            <p class="mt-3 text-sm text-zinc-400 leading-relaxed">{scenario}</p>
            <.link
              navigate={href}
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-400 hover:text-brand-300"
            >
              Read the post-mortem <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
            </.link>
          </div>
        <% end %>
      </div>

      <p class="mt-12 text-center text-sm">
        <.link
          navigate={~p"/use-cases"}
          class="inline-flex items-center gap-1 font-medium text-brand-400 hover:text-brand-300"
        >
          See every use case — the daily wins and the war stories
          <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </p>
    </div>
  </section>

  <%!-- Zero Trust validation — the third-party-framework authority capstone,
       last of the proof run (comparison → use cases → here) before pricing.
       Unshaded, alternating between the shaded use cases above and shaded
       pricing below. --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">Zero Trust for AI Agents</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          The framework a frontier lab published — enforced by emisar.
        </p>
        <p class="mt-6 text-lg leading-8 text-zinc-400 text-pretty">
          Anthropic's
          <a
            href="https://cdn.prod.website-files.com/6889473510b50328dbb70ae6/6a1611a04085d7cd3dadc924_Claude-eBook-Zero-Trust-for-AI-Agents-05182026.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand-300 underline decoration-zinc-700 underline-offset-4 hover:text-brand-200"
          >
            Zero Trust for AI Agents
          </a>
          guide says an agent with access to real systems needs four things: least agency,
          deny-by-default tools, human approval for high-risk actions, and an audit trail no one
          can edit. emisar enforces exactly that. And the controls the framework reserves for its
          top tiers ship on emisar's Free plan.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <%= for {principle, detail} <- [
          {"Least agency", "The agent only sees the actions you declared"},
          {"Human in the loop", "High-risk actions stop for a one-click approval"},
          {"Full audit trail", "Searchable portal audit, a tamper-evident hash-chained host journal, and SIEM export"},
          {"Assume breach", "Even a jailbroken agent can't get past the catalog"}
        ] do %>
          <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6 text-left">
            <h3 class="text-sm font-semibold text-brand-300">{principle}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{detail}</p>
          </div>
        <% end %>
      </div>

      <div class="mt-10 text-center">
        <.link
          navigate={~p"/zero-trust"}
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-400 hover:text-brand-300"
        >
          See emisar mapped to the framework, control by control
          <.icon name="hero-arrow-right" class="h-4 w-4" />
        </.link>
        <p class="mx-auto mt-4 max-w-xl text-xs leading-relaxed text-zinc-500">
          Not affiliated with or endorsed by Anthropic. We cite the framework because emisar is
          built to the control set it describes.
        </p>
      </div>
    </div>
  </section>

  <%!-- Pricing teaser --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div data-reveal class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-base font-semibold text-brand-400">Pricing</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Pay per runner. Not per seat.
        </p>
        <p class="mt-6 text-lg text-zinc-400 leading-relaxed">
          Free for 3 runners and 1 user. Team is $20/runner/month with unlimited users.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Free</h3>
          <p class="mt-2 text-sm text-zinc-400">For homelab and tinkering.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white text-balance">$0</span>
            <span class="text-sm text-zinc-500">/ forever</span>
          </div>
          <.marketing_button variant={:secondary} href={~p"/sign_up"} block class="mt-8">
            Start free
          </.marketing_button>
          <ul class="mt-8 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" /> 3 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" /> 1 user
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              7-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              Community support
            </li>
          </ul>
        </div>
        <div class="relative rounded-2xl border-2 border-brand-500/60 bg-zinc-950/80 p-8 shadow-2xl shadow-brand-950/40">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-3 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-zinc-950">
            Most popular
          </span>
          <h3 class="text-lg font-semibold text-white">Team</h3>
          <p class="mt-2 text-sm text-zinc-400">For teams running real production.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white text-balance">$20</span>
            <span class="text-sm text-zinc-500">/ runner / month</span>
          </div>
          <.marketing_button href={~p"/sign_up"} block class="mt-8">
            Start free
          </.marketing_button>
          <ul class="mt-8 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              Up to 100 runners
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" /> Unlimited users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              90-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              Automated invoices, email support
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h3 class="text-lg font-semibold text-white">Enterprise</h3>
          <p class="mt-2 text-sm text-zinc-400">For regulated environments &amp; fleets.</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white text-balance">Custom</span>
          </div>
          <.marketing_button
            variant={:secondary}
            href={EmisarWeb.MailTo.sales()}
            block
            class="mt-8"
          >
            Talk to sales
          </.marketing_button>
          <ul class="mt-8 space-y-2 text-sm text-zinc-300">
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              Unlimited runners &amp; users
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              365-day audit retention
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              Security and procurement review
            </li>
            <li class="flex gap-2">
              <.icon name="hero-check" class="h-4 w-4 flex-none text-brand-400" />
              Design-partner deployment planning
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <%!-- FAQ --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-base font-semibold text-brand-400">FAQ</h2>
        <p class="mt-2 text-4xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          The skeptical questions, answered.
        </p>
      </div>

      <div class="mt-16 divide-y divide-zinc-900 overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between transition-colors hover:bg-zinc-900/30 px-8 py-6 text-base font-semibold text-zinc-50">
              {q}
              <.icon
                name="hero-chevron-down"
                class="h-5 w-5 shrink-0 text-zinc-500 transition duration-200 group-hover:text-zinc-300 group-open:rotate-180 group-open:text-brand-400"
              />
            </summary>
            <p class="px-8 pb-6 text-sm text-zinc-400 leading-relaxed">{a}</p>
          </details>
        <% end %>
      </div>
    </div>
  </section>

  <%!-- Final CTA --%>
  <section class="pb-24 sm:pb-32">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-lg border border-brand-500/30 bg-zinc-950 p-12 sm:p-16">
        <div class="glow-emerald pointer-events-none absolute inset-0" aria-hidden="true"></div>
        <div class="grain pointer-events-none absolute inset-0" aria-hidden="true"></div>
        <div class="relative text-center">
          <.marketing_heading tag="h2" scale={:section}>
            Give your AI production access. You keep the last word.
          </.marketing_heading>
          <p class="mx-auto mt-6 max-w-xl text-lg text-zinc-400 leading-relaxed">
            Three runners. Seven-day audit. No credit card. Read the quickstart and
            run your first gated action.
          </p>
          <form
            action={~p"/sign_up"}
            method="get"
            class="mx-auto mt-10 flex max-w-md flex-col items-center gap-3 sm:flex-row"
          >
            <label for="cta-email" class="sr-only">Work email</label>
            <input
              type="email"
              name="email"
              id="cta-email"
              placeholder="you@company.com"
              class="w-full rounded-lg border-0 bg-zinc-900/80 px-4 py-2.5 text-sm text-white ring-1 ring-zinc-800 placeholder:text-zinc-500 focus:ring-2 focus:ring-brand-500"
            />
            <.marketing_button type="submit" icon="hero-arrow-right" class="w-full sm:w-auto">
              Start free
            </.marketing_button>
          </form>
          <p class="mt-5 text-sm text-zinc-400">
            Prefer a walkthrough first? <a
              href="https://calendly.com/andrew-dryga/emisar-demo"
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-brand-400 hover:text-brand-300"
            >Book a 30-minute demo</a>.
          </p>
          <p class="mt-4 text-xs text-zinc-400">
            No credit card. Cancel anytime. Your audit log is yours to export.
          </p>
        </div>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
