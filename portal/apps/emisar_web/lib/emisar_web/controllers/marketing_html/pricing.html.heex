<%!-- ============================================================
  Pricing — three tiers + FAQ
============================================================ --%>

<div class="bg-zinc-950 text-zinc-100">
  <.marketing_nav current_user={@current_user} current={:pricing} />

  <%!-- Hero --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <.marketing_heading tag="h1" scale={:display}>
          Per runner, not per seat.
        </.marketing_heading>
        <p class="mt-6 text-lg leading-8 text-zinc-400 text-pretty">
          Free covers one user and three runners; Team and Enterprise add
          unlimited users and longer audit retention.
        </p>
      </div>

      <%!-- Tiers --%>
      <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-6 lg:max-w-none lg:grid-cols-3 lg:gap-8">
        <%!-- Free --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h2 class="text-lg font-semibold text-zinc-50">Free</h2>
          <p class="mt-2 text-sm text-zinc-400">For evaluation and solo use.</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-5xl font-bold tracking-tight text-zinc-50">$0</span>
            <span class="text-sm font-semibold text-zinc-400">/ forever</span>
          </p>
          <.marketing_button
            variant={:secondary}
            href={~p"/sign_up"}
            size={:lg}
            block
            class="mt-8"
          >
            Start free
          </.marketing_button>
          <ul class="mt-8 space-y-3 text-sm text-zinc-300">
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" /> 3 runners
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" /> 1 user
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              7-day audit retention
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              All policy features
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              Community support
            </li>
          </ul>
        </div>

        <%!-- Team --%>
        <div class="relative rounded-2xl border-2 border-brand-500 bg-zinc-950/80 p-8 shadow-2xl shadow-brand-900/30">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-4 py-1 text-xs font-semibold text-zinc-950">
            Most popular
          </span>
          <h2 class="text-lg font-semibold text-brand-300">Team</h2>
          <p class="mt-2 text-sm text-zinc-400">For production teams.</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-5xl font-bold tracking-tight text-zinc-50">$20</span>
            <span class="text-sm font-semibold text-zinc-400">/ runner / mo</span>
          </p>
          <.marketing_button href={~p"/sign_up"} size={:lg} block class="mt-8">
            Start free
          </.marketing_button>
          <ul class="mt-8 space-y-3 text-sm text-zinc-300">
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-brand-400" />
              Up to 100 runners
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-brand-400" />
              Unlimited users
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-brand-400" />
              90-day audit retention
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-brand-400" />
              Monthly invoices
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-brand-400" />
              Email support
            </li>
          </ul>
        </div>

        <%!-- Enterprise --%>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-8">
          <h2 class="text-lg font-semibold text-zinc-50">Enterprise</h2>
          <p class="mt-2 text-sm text-zinc-400">For design partners and regulated teams.</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-5xl font-bold tracking-tight text-zinc-50">Custom</span>
          </p>
          <.marketing_button variant={:secondary} href={~p"/demo"} size={:lg} block class="mt-8">
            Talk to sales
          </.marketing_button>
          <ul class="mt-8 space-y-3 text-sm text-zinc-300">
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              Unlimited runners and users
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              365-day audit retention
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              SSO + SCIM directory sync
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              Security and procurement review
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              Design-partner deployment planning
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              Rollout support
            </li>
            <li class="flex items-start gap-3">
              <.icon name="hero-check" class="mt-0.5 h-5 w-5 flex-none text-zinc-500" />
              Custom commercial terms
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <%!-- How it works — answers "how hard is adoption?" right at the decision point --%>
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold text-brand-400">Up and running in minutes</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-zinc-50 sm:text-4xl text-balance">
          From sign-up to your first audited action
        </h2>
      </div>
      <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6">
          <div class="text-xs font-semibold uppercase tracking-wider text-brand-400">Step 1</div>
          <h3 class="mt-2 text-base font-semibold text-zinc-100">Create an account</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">
            Free, no credit card. You're in the dashboard in under a minute.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6">
          <div class="text-xs font-semibold uppercase tracking-wider text-brand-400">Step 2</div>
          <h3 class="mt-2 text-base font-semibold text-zinc-100">Install a runner</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">
            One command on a Linux or macOS host — the dashboard hands you the install
            one-liner and watches it connect.
          </p>
        </div>
        <div class="rounded-2xl border border-zinc-900 bg-zinc-950/60 p-6">
          <div class="text-xs font-semibold uppercase tracking-wider text-brand-400">Step 3</div>
          <h3 class="mt-2 text-base font-semibold text-zinc-100">Run an action</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">
            Dispatch from the dashboard, or point Claude, ChatGPT, or Cursor at your
            account's MCP endpoint — and let policy decide.
          </p>
        </div>
      </div>
      <div class="mt-8 text-center">
        <.link
          navigate={~p"/docs/quickstart"}
          class="inline-flex items-center gap-1 text-sm font-semibold text-brand-400 hover:text-brand-300"
        >
          Read the quickstart <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <%!-- Comparison table --%>
  <section class="border-y border-zinc-900 bg-zinc-950/40 py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <.marketing_heading tag="h2" scale={:section}>
          Compare plans
        </.marketing_heading>
      </div>
      <div class="mx-auto mt-12 max-w-5xl overflow-x-auto rounded-2xl border border-zinc-900">
        <table class="w-full min-w-[720px] divide-y divide-zinc-900 text-sm">
          <thead class="bg-zinc-950/80">
            <tr>
              <th scope="col" class="px-6 py-4 text-left font-semibold text-zinc-300">Feature</th>
              <th scope="col" class="px-6 py-4 text-left font-semibold text-zinc-300">Free</th>
              <th scope="col" class="px-6 py-4 text-left font-semibold text-brand-300">Team</th>
              <th scope="col" class="px-6 py-4 text-left font-semibold text-zinc-300">
                Enterprise
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-900 bg-zinc-950/40">
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Runners</td>
              <td class="px-6 py-4 text-zinc-400">3</td>
              <td class="px-6 py-4 text-zinc-400">100</td>
              <td class="px-6 py-4 text-zinc-400">Unlimited</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Users</td>
              <td class="px-6 py-4 text-zinc-400">1</td>
              <td class="px-6 py-4 text-zinc-400">Unlimited</td>
              <td class="px-6 py-4 text-zinc-400">Unlimited</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Audit retention</td>
              <td class="px-6 py-4 text-zinc-400">7 days</td>
              <td class="px-6 py-4 text-zinc-400">90 days</td>
              <td class="px-6 py-4 text-zinc-400">365 days</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Policy + approvals</td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">MCP server</td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Pack trust + drift blocking</td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">SIEM export</td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">SSO + SCIM directory sync</td>
              <td class="px-6 py-4 text-zinc-600">—</td>
              <td class="px-6 py-4 text-zinc-600">—</td>
              <td class="px-6 py-4 text-zinc-400">
                <.icon name="hero-check" class="h-5 w-5 text-brand-400" />
              </td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Deployment planning</td>
              <td class="px-6 py-4 text-zinc-600">—</td>
              <td class="px-6 py-4 text-zinc-600">—</td>
              <td class="px-6 py-4 text-zinc-400">Design partner</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-medium text-zinc-100">Support</td>
              <td class="px-6 py-4 text-zinc-400">Community</td>
              <td class="px-6 py-4 text-zinc-400">Email</td>
              <td class="px-6 py-4 text-zinc-400">Rollout support</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <%!-- FAQ --%>
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <.marketing_heading tag="h2" scale={:section}>
        Frequently asked questions
      </.marketing_heading>
      <div class="mt-12 divide-y divide-zinc-900 overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950/60">
        <%= for {q, a} <- @faqs do %>
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between transition-colors hover:bg-zinc-900/30 px-8 py-6 text-base font-semibold text-zinc-50">
              {q}
              <.icon
                name="hero-chevron-down"
                class="h-5 w-5 shrink-0 text-zinc-500 transition duration-200 group-hover:text-zinc-300 group-open:rotate-180 group-open:text-brand-400"
              />
            </summary>
            <p class="px-8 pb-6 text-sm leading-6 text-zinc-400">{a}</p>
          </details>
        <% end %>
      </div>
      <p class="mt-8 text-sm text-zinc-400">
        More on how we handle data, secrets, and audit on the <.link
          navigate={~p"/security"}
          class="text-brand-400 hover:text-brand-300"
        >security page</.link>, and how billing and cancellations work in our <.link
          navigate={~p"/refund-policy"}
          class="text-brand-400 hover:text-brand-300"
        >refund policy</.link>.
      </p>
    </div>
  </section>

  <.marketing_footer />
</div>
