          href={~p"/sign_up"}
          class="inline-flex items-center gap-1 font-medium text-indigo-400 hover:text-indigo-300"
        >
          Start free — connect a runner <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
        <.link
          navigate={~p"/docs/security-model"}
          class="inline-flex items-center gap-1 font-medium text-indigo-400 hover:text-indigo-300"
        >
          How the trust boundary works <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
        <.link
          navigate={~p"/docs/action-packs"}
          class="inline-flex items-center gap-1 font-medium text-indigo-400 hover:text-indigo-300"
        >
          Author your own pack <.icon name="hero-arrow-right" class="h-3.5 w-3.5" />
        </.link>
      </div>
    </div>
  </section>

  <.marketing_footer />
</div>
