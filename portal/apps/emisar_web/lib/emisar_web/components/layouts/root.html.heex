<!DOCTYPE html>
<html lang="en" class="h-full bg-zinc-950 text-zinc-100 [scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Robots: noindex on every /app/* and auth route via the
          conn-level noindex assign; everything else indexable. --%>
    <meta :if={assigns[:noindex]} name="robots" content="noindex, nofollow" />
    <meta
      name="description"
      content={
        assigns[:meta_description] ||
          "Connect any MCP client to a finite action catalog, enforced on-host with pack trust, policy gates, human approvals, a searchable audit trail, and a hash-chained runner journal."
      }
    />
    <link :if={assigns[:canonical_url]} rel="canonical" href={@canonical_url} />
    <%!-- RSS auto-discovery for the changelog — only on the marketing surface
         (canonical_url is set there, never on the console). --%>
    <link
      :if={assigns[:canonical_url]}
      rel="alternate"
      type="application/rss+xml"
      title="emisar changelog"
      href="https://emisar.dev/changelog.xml"
    />
    <.live_title
      default="emisar — give AI tools approved infrastructure actions, not SSH"
      suffix=" · emisar"
    >
      {assigns[:page_title]}
    </.live_title>

    <%!-- Open Graph / Twitter Card --%>
    <meta property="og:type" content={assigns[:og_type] || "website"} />
    <meta property="og:title" content={assigns[:og_title] || assigns[:page_title] || "emisar"} />
    <meta
      property="og:description"
      content={
        assigns[:og_description] || assigns[:meta_description] ||
          "The best way to give your AI agents access to production."
      }
    />
    <meta
      property="og:image"
      content={assigns[:og_image] || "https://emisar.dev/images/og/emisar-og.webp"}
    />
    <meta property="og:url" content={assigns[:canonical_url] || "https://emisar.dev"} />
    <meta property="og:site_name" content="emisar" />
    <meta
      name="twitter:card"
      content="summary_large_image"
    />
    <meta name="twitter:title" content={assigns[:og_title] || assigns[:page_title] || "emisar"} />
    <meta
      name="twitter:description"
      content={
        assigns[:og_description] || assigns[:meta_description] ||
          "The best way to give your AI agents access to production."
      }
    />
    <meta
      name="twitter:image"
      content={assigns[:og_image] || "https://emisar.dev/images/og/emisar-og.webp"}
    />

    <%!-- JSON-LD: only emitted on routes that set @json_ld --%>
    <%= if assigns[:json_ld] do %>
      <script type="application/ld+json" nonce={assigns[:csp_nonce]}>
        <%= Phoenix.HTML.raw(@json_ld) %>
      </script>
    <% end %>

    <link rel="icon" type="image/svg+xml" href={~p"/favicon.svg"} />
    <link rel="alternate icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link rel="apple-touch-icon" href={~p"/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <meta name="theme-color" content="#0a0a0b" />
    <%!-- Preload the variable font (fonts fetch in CORS mode, so crossorigin
         is required or it double-fetches) so it loads in parallel with the CSS
         instead of after the @font-face is parsed — faster LCP on the
         text-led marketing pages. --%>
    <link
      rel="preload"
      href={~p"/fonts/InterVariable.woff2"}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <%!-- LiveView pages need app.js (LiveSocket + hooks); the static,
          server-rendered marketing pages load only the lean marketing.js.
          `@app_js?` is set by the global LiveView on_mount hook, so it's
          present on every live render and absent on controller renders. --%>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={if assigns[:app_js?], do: ~p"/assets/app.js", else: ~p"/assets/marketing.js"}
    >
    </script>
  </head>
  <body class={
    [
      "h-full bg-zinc-950 text-zinc-100 antialiased",
      # Tag the server-rendered marketing/docs surface (not the LiveView console,
      # which sets app_js?) so app.css can scope its expressive inline-code styling
      # to marketing and leave the calm console's code styling alone.
      !assigns[:app_js?] && "marketing"
    ]
  }>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-brand-500 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-zinc-950"
    >
      Skip to main content
    </a>
    {@inner_content}
  </body>
</html>
