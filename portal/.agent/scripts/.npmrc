# Supply-chain hardening for the docs-screenshot tooling — the repo's only
# npm surface. npm has no native release-age cooldown (dep-age-gate.py + the
# Dependabot cooldown carry that policy), so the controls here are:
#   * ignore-scripts — no lifecycle scripts, the classic npm-worm vector;
#     puppeteer-core needs none (it drives an already-installed Chrome).
#   * save-exact — future adds land pinned, matching the lockfile-only policy.
ignore-scripts=true
save-exact=true
