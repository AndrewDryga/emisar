# Copy to terraform.tfvars (gitignored) and set project_id. Everything else
# already defaults to emisar.dev's live production values in variables.tf.
#
#   terraform login   # if using the Terraform Cloud backend in main.tf
#   terraform init
#   terraform plan
#
# If the Terraform Cloud workspace uses remote execution, set these as workspace
# variables instead; .terraformignore excludes local *.tfvars from any upload.

project_id = "emisar" # the GCP project that hosts the Cloud DNS zone

# --- Overrides (defaults in variables.tf already match emisar.dev) ------------
# domain   = "emisar.dev"
# dns_name = "emisar.dev."
# fly_ipv4 = "37.16.18.178"
# fly_ipv6 = "2a09:8280:1::11e:a273:0"

# DMARC ramp — start at none (monitor), move up once rua reports look clean:
# dmarc_policy = "none"          # → "quarantine" → "reject"
# dmarc_rua    = "mailto:dmarc@emisar.dev"

# CAA — Fly (apex) and BetterUptime (status.) both issue via Let's Encrypt:
# caa_issuers = ["letsencrypt.org"]
