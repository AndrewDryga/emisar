# Copy to terraform.tfvars (gitignored) and set project_id — OR, since state and
# variables live in Terraform Cloud (org Dryga / project emisar / workspace
# emisar), set everything as workspace variables there instead. SECRET variables
# (paddle_*, postmark_*, sentry_dsn, mixpanel_token) must ONLY be set as SENSITIVE
# TFC workspace variables — never in a tfvars file, even a gitignored one.
#
#   terraform login && terraform init && terraform plan
#   (apply is the deliberate Fly→GCP migration step)

project_id = "emisar" # the GCP project to deploy into

# --- Overrides (defaults in variables.tf) ------------------------------------
# region   = "us-central1"
# domain   = "emisar.dev"
# dns_name = "emisar.dev."

# Compute
# machine_type    = "e2-standard-2"
# instance_count  = 2                                  # >1 clusters via Emisar.Cluster.GCE
# container_image = "ghcr.io/andrewdryga/emisar:latest" # public GHCR; pin a digest for prod
# disable_billing = false                              # true → Paddle stub, no paddle_* needed

# Database
# db_tier         = "db-custom-1-3840"   # a shared-core tier can't run REGIONAL HA
# db_disk_size_gb = 20

# Monitoring
# alert_email = "ops@emisar.dev"

# DNS email posture
# dmarc_policy = "none"              # → "quarantine" → "reject"
# dmarc_rua    = "mailto:dmarc@emisar.dev"
# caa_issuers  = ["letsencrypt.org", "pki.goog"]   # BetterUptime + Google-managed cert
