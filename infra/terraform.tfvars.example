# Copy to terraform.tfvars (gitignored) and set project_id. Everything else
# defaults to emisar's production values in variables.tf. Then:
#   terraform init && terraform plan   (apply is the deliberate GCP-migration step)

project_id = "emisar" # the GCP project to deploy into

# --- Overrides (defaults in variables.tf) ------------------------------------
# region       = "us-central1"
# domain       = "emisar.dev"
# dns_name     = "emisar.dev."

# Compute
# machine_type   = "e2-standard-2"
# instance_count = 2                 # >1 clusters via Emisar.Cluster.GCE
# image_tag      = "latest"          # pin a version/digest for a reproducible rollout
# disable_billing = false            # true → ship the Paddle stub (no paddle-* secrets)

# Database
# db_tier         = "db-custom-1-3840"   # a shared-core tier can't run REGIONAL HA
# db_disk_size_gb = 20

# Monitoring
# alert_email = "ops@emisar.dev"

# DNS email posture
# dmarc_policy = "none"              # → "quarantine" → "reject"
# dmarc_rua    = "mailto:dmarc@emisar.dev"
# caa_issuers  = ["letsencrypt.org", "pki.goog"]   # BetterUptime + Google-managed cert
