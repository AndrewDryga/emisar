#!/usr/bin/env bash
set -euo pipefail

# A configured default zone must not narrow the portal picker. Every operation
# that targets a VM passes its selected zone explicitly.
export CLOUDSDK_COMPUTE_ZONE=
export CLOUDSDK_COMPUTE_REGION=

usage() {
  cat <<'EOF'
Usage: infra/scripts/portal [options] <command> [args...]

Operate the Emisar portal VMs through IAP and OS Login.

Options:
  --project PROJECT        GCP project (defaults to EMISAR_GCP_PROJECT or gcloud config)
  --host NAME              Select a portal VM by name (repeatable; skips fzf)
  --list-hosts             Print eligible portal VM names and exit
  --reuse-last-selection   Reuse this shell session's last VM selection
  -h, --help               Show this help

Commands:
  ssh                      Open an interactive SSH session (one VM)
  remsh                    Attach an IEx shell to the running release (one VM)
  logs [-f|--follow]       Show or follow the latest portal container logs
  journal                  Show the latest portal systemd journal
  status                   Show the portal systemd service status
  version                  Show the deployed Emisar release version
  cmd <shell-command>      Run a shell command on the selected VMs

The picker supports multiple selections with fzf's Tab key. Multi-selection is
available for logs, journal, status, version, and cmd. Automation can repeat
--host to select the exact VMs it needs without opening the picker.
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required but not installed."
}

USE_LAST_SELECTION=0
LIST_HOSTS=0
LOG_FOLLOW=0
PROJECT="${EMISAR_GCP_PROJECT:-}"
REQUESTED_HOSTS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      [[ $# -ge 2 ]] || die "--project requires a value."
      PROJECT="$2"
      shift 2
      ;;
    --host)
      [[ $# -ge 2 ]] || die "--host requires a value."
      [[ "$2" =~ ^[a-z]([-a-z0-9]*[a-z0-9])?$ ]] || die "invalid host name: $2"
      if [[ ${#REQUESTED_HOSTS[@]} -gt 0 ]]; then
        for requested_host in "${REQUESTED_HOSTS[@]}"; do
          [[ "$requested_host" != "$2" ]] || die "host selected more than once: $2"
        done
      fi
      REQUESTED_HOSTS+=("$2")
      shift 2
      ;;
    --list-hosts)
      LIST_HOSTS=1
      shift
      ;;
    --reuse-last-selection)
      USE_LAST_SELECTION=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

if [[ "$LIST_HOSTS" -eq 1 ]]; then
  [[ $# -eq 0 ]] || die "--list-hosts does not accept a command."
  [[ "$USE_LAST_SELECTION" -eq 0 && ${#REQUESTED_HOSTS[@]} -eq 0 ]] || \
    die "--list-hosts cannot be combined with --host or --reuse-last-selection."
else
  [[ $# -gt 0 ]] || {
    usage >&2
    exit 1
  }

  COMMAND="$1"
  shift

  case "$COMMAND" in
    ssh | remsh | journal | status | version)
      [[ $# -eq 0 ]] || die "$COMMAND does not accept arguments."
      ;;
    logs)
      if [[ $# -eq 1 && ("$1" == "-f" || "$1" == "--follow") ]]; then
        LOG_FOLLOW=1
      elif [[ $# -gt 0 ]]; then
        die "logs accepts only -f or --follow."
      fi
      ;;
    cmd)
      [[ $# -gt 0 ]] || die "cmd requires a shell command."
      ;;
    *)
      die "unknown command: $COMMAND"
      ;;
  esac
fi

require_command gcloud
if [[ -z "$PROJECT" ]]; then
  PROJECT="$(gcloud config get-value project 2>/dev/null || true)"
fi
[[ -n "$PROJECT" && "$PROJECT" != "(unset)" ]] || \
  die "no GCP project configured; pass --project or set EMISAR_GCP_PROJECT."

[[ "$USE_LAST_SELECTION" -eq 0 || ${#REQUESTED_HOSTS[@]} -eq 0 ]] || \
  die "--host cannot be combined with --reuse-last-selection."

list_portal_instances() {
  gcloud compute instances list \
    --project="$PROJECT" \
    --filter='labels.cluster_name=emisar' \
    --sort-by=creationTimestamp \
    --format='value(name,zone.basename(),status,creationTimestamp,machineType.basename())'
}

if [[ "$LIST_HOSTS" -eq 1 ]]; then
  PORTAL_INVENTORY="$(list_portal_instances)"
  while IFS=$'\t' read -r name _; do
    [[ -n "$name" ]] && printf '%s\n' "$name"
  done <<<"$PORTAL_INVENTORY"
  exit 0
fi

if [[ "$USE_LAST_SELECTION" -eq 0 && ${#REQUESTED_HOSTS[@]} -eq 0 ]]; then
  require_command fzf
fi

# Use the topmost shell PID when the terminal does not expose its own session
# identifier. This keeps `watch ... --reuse-last-selection` in the same cache.
find_top_shell_pid() {
  local pid=$$ result="" comm ppid

  while :; do
    comm="$(ps -o comm= -p "$pid" 2>/dev/null || true)"
    comm="${comm##*/}"
    comm="${comm#-}"
    case "$comm" in
      zsh | bash | fish | sh | dash | ksh) result="$pid" ;;
    esac

    ppid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
    [[ -z "$ppid" || "$ppid" == "0" || "$ppid" == "1" || "$ppid" == "$pid" ]] && break
    pid="$ppid"
  done

  [[ -n "$result" ]] && printf '%s' "$result"
}

SESSION_HINT="${EMISAR_PORTAL_SESSION_KEY:-${TMUX_PANE:-${SHELL_SESSION_ID:-${TERM_SESSION_ID:-${ITERM_SESSION_ID:-}}}}}"
if [[ -z "$SESSION_HINT" ]]; then
  SESSION_HINT="$(find_top_shell_pid || true)"
fi
SESSION_HINT="${SESSION_HINT:-${PPID:-$$}}"
SESSION_KEY="$(printf '%s' "$SESSION_HINT" | tr -c 'A-Za-z0-9._-' '_')"
PROJECT_KEY="$(printf '%s' "$PROJECT" | tr -c 'A-Za-z0-9._-' '_')"
DEFAULT_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/emisar/portal"
SELECTION_CACHE_FILE="${EMISAR_PORTAL_LAST_SELECTION_FILE:-$DEFAULT_CACHE_DIR/${PROJECT_KEY}_session_${SESSION_KEY:-default}.selection}"

gssh() {
  local name="$1"
  local zone="$2"
  shift 2

  gcloud compute ssh "$name" \
    --project="$PROJECT" \
    --zone="$zone" \
    --tunnel-through-iap \
    "$@"
}

serialize_instances() {
  local line

  for line in "${INSTANCES[@]}"; do
    printf '%s\n' "$line"
  done
}

load_instances() {
  local raw="$1"
  local line

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    INSTANCES+=("$line")
  done <<<"$raw"
}

build_remote_command() {
  if [[ $# -eq 1 ]]; then
    printf '%s' "$1"
    return
  fi

  local arg result=""
  for arg in "$@"; do
    result="${result:+$result }$(printf '%q' "$arg")"
  done
  printf '%s' "$result"
}

portal_command() {
  case "$COMMAND" in
    logs)
      if [[ "$LOG_FOLLOW" -eq 1 ]]; then
        printf '%s' 'sudo docker logs --tail=200 --follow emisar'
      else
        printf '%s' 'sudo docker logs --tail=200 emisar'
      fi
      ;;
    journal)
      printf '%s' 'sudo journalctl --unit=emisar.service --lines=200 --no-pager'
      ;;
    status)
      printf '%s' 'sudo systemctl status emisar.service --no-pager'
      ;;
    version)
      printf '%s' "sudo docker exec emisar cut -d ' ' -f2 /app/releases/start_erl.data"
      ;;
    cmd)
      printf 'bash -lc %q' "$(build_remote_command "$@")"
      ;;
  esac
}

INSTANCES=()
if [[ ${#REQUESTED_HOSTS[@]} -gt 0 ]]; then
  PORTAL_INVENTORY="$(list_portal_instances)"
  for requested_host in "${REQUESTED_HOSTS[@]}"; do
    MATCHES="$(awk -F '\t' -v host="$requested_host" '$1 == host' <<<"$PORTAL_INVENTORY")"
    [[ -n "$MATCHES" ]] || die "portal host not found: $requested_host"
    load_instances "$MATCHES"
  done
elif [[ "$USE_LAST_SELECTION" -eq 1 ]]; then
  RAW_SELECTION="${EMISAR_PORTAL_LAST_SELECTION:-}"
  if [[ -z "$RAW_SELECTION" && -f "$SELECTION_CACHE_FILE" ]]; then
    RAW_SELECTION="$(<"$SELECTION_CACHE_FILE")"
  fi
  [[ -n "$RAW_SELECTION" ]] || \
    die "no cached portal selection found; run without --reuse-last-selection first."
  load_instances "$RAW_SELECTION"
else
  RAW_SELECTION="$(
    list_portal_instances | \
      fzf \
        --multi \
        --delimiter=$'\t' \
        --with-nth=1,2,3,4,5 \
        --header=$'NAME\tZONE\tSTATUS\tCREATED\tMACHINE TYPE'
  )" || exit $?

  [[ -n "$RAW_SELECTION" ]] || die "no portal instances selected."
  load_instances "$RAW_SELECTION"

  umask 077
  mkdir -p "$(dirname "$SELECTION_CACHE_FILE")"
  serialize_instances >"$SELECTION_CACHE_FILE"
fi

[[ ${#INSTANCES[@]} -gt 0 ]] || die "no portal instances selected."

if [[ ${#INSTANCES[@]} -gt 1 && ("$COMMAND" == "ssh" || "$COMMAND" == "remsh") ]]; then
  die "$COMMAND supports exactly one selected VM."
fi

read_instance() {
  local instance="$1"
  IFS=$'\t' read -r VM_NAME VM_ZONE _ <<<"$instance"
  [[ -n "$VM_NAME" && -n "$VM_ZONE" ]] || die "invalid cached VM selection."
}

if [[ "$COMMAND" == "ssh" ]]; then
  read_instance "${INSTANCES[0]}"
  printf 'Starting SSH session on %s (%s)...\n' "$VM_NAME" "$VM_ZONE"
  gssh "$VM_NAME" "$VM_ZONE"
  exit 0
fi

if [[ "$COMMAND" == "remsh" ]]; then
  read_instance "${INSTANCES[0]}"
  printf 'Attaching to the Emisar release on %s (%s)...\n' "$VM_NAME" "$VM_ZONE"
  gssh "$VM_NAME" "$VM_ZONE" \
    --command='sudo docker exec -it emisar /app/bin/emisar remote' \
    -- -t
  exit 0
fi

REMOTE_COMMAND="$(portal_command "$@")"

if [[ ${#INSTANCES[@]} -eq 1 ]]; then
  read_instance "${INSTANCES[0]}"
  printf 'Running %s on %s (%s)...\n' "$COMMAND" "$VM_NAME" "$VM_ZONE"
  gssh "$VM_NAME" "$VM_ZONE" --command="$REMOTE_COMMAND"
  exit 0
fi

RESET_COLOR=""
COLORS=("" "" "" "" "" "")
if [[ -t 1 ]]; then
  RESET_COLOR="$(printf '\033[0m')"
  COLORS=(
    "$(printf '\033[1;31m')"
    "$(printf '\033[1;32m')"
    "$(printf '\033[1;33m')"
    "$(printf '\033[1;34m')"
    "$(printf '\033[1;35m')"
    "$(printf '\033[1;36m')"
  )
fi

VM_NAMES=""
for instance in "${INSTANCES[@]}"; do
  read_instance "$instance"
  VM_NAMES="${VM_NAMES:+$VM_NAMES, }$VM_NAME"
done
printf "Running %s over SSH on %s at %s...\n" "$COMMAND" "$VM_NAMES" "$(date)"

PIDS=()
COLOR_INDEX=0
for instance in "${INSTANCES[@]}"; do
  read_instance "$instance"
  COLOR="${COLORS[$((COLOR_INDEX % ${#COLORS[@]}))]}"
  COLOR_INDEX=$((COLOR_INDEX + 1))

  gssh "$VM_NAME" "$VM_ZONE" --command="$REMOTE_COMMAND" 2>&1 | \
    sed "s/^/${COLOR}[$VM_NAME]${RESET_COLOR} /" &
  PIDS+=("$!")
done

FAILED=0
for pid in "${PIDS[@]}"; do
  wait "$pid" || FAILED=1
done
exit "$FAILED"
